{#
  Native Kubernetes manifests for the Syncthing deployment, deployed via ArgoCD.
  Contains the Services to expose the GUI and sync ports, and the StatefulSet
  that manages the Syncthing pod and its persistent storage.

  Storage is split across two volumes:
    - syncthing-data (Longhorn, RWO): Syncthing config and index DB, mounted at
      /var/syncthing. Managed by the StatefulSet volumeClaimTemplate.
    - syncthing-nfs-data (NFS, RWX): Synced folder data, mounted at
      /var/syncthing/data. Pre-created by syncthing.yml before ArgoCD sync.

  Variables:
    syncthing_namespace:        Kubernetes namespace where Syncthing is deployed.
    syncthing_image:            Docker image for Syncthing.
    syncthing_image_tag:        Docker image tag for Syncthing.
    syncthing_storage_class:    StorageClass to use for the config PersistentVolumeClaim.
    syncthing_storage_size:     Size of the config PersistentVolumeClaim.
    syncthing_gui_port:         Port for the Web GUI.
    syncthing_sync_port:        Port for the sync protocol.
    syncthing_discovery_port:   Port for local discovery.
    syncthing_sync_hostname:    DNS hostname for the sync service.
    syncthing_default_folder_path: Default path suggested when adding a new folder
                                in the Syncthing UI.
    nfs_group_gid:              GID of the NFS users group. Added as a supplemental
                                group via fsGroup so the Syncthing process can
                                write to the NFS export.
    nonroot_uid:                Non-root UID the pod runs as. Read from
                                group_vars so every service can inherit the
                                same well-known value.
#}
---
apiVersion: v1
kind: Service
metadata:
  name: syncthing-gui
  namespace: '{{ syncthing_namespace }}'
  labels:
    app.kubernetes.io/name: syncthing
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: syncthing
  ports:
    - name: http
      port: {{ syncthing_gui_port }}
      targetPort: {{ syncthing_gui_port }}
      protocol: TCP
---
apiVersion: v1
kind: Service
metadata:
  name: syncthing-sync
  namespace: '{{ syncthing_namespace }}'
  annotations:
    external-dns.alpha.kubernetes.io/hostname: '{{ syncthing_sync_hostname }}'
  labels:
    app.kubernetes.io/name: syncthing
spec:
  type: LoadBalancer
  externalTrafficPolicy: Local
  selector:
    app.kubernetes.io/name: syncthing
  ports:
    - name: tcp-sync
      port: {{ syncthing_sync_port }}
      targetPort: {{ syncthing_sync_port }}
      protocol: TCP
    - name: udp-sync
      port: {{ syncthing_sync_port }}
      targetPort: {{ syncthing_sync_port }}
      protocol: UDP
    - name: udp-discovery
      port: {{ syncthing_discovery_port }}
      targetPort: {{ syncthing_discovery_port }}
      protocol: UDP
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: syncthing
  namespace: '{{ syncthing_namespace }}'
  labels:
    app.kubernetes.io/name: syncthing
spec:
  serviceName: syncthing-gui
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: syncthing
  template:
    metadata:
      labels:
        app.kubernetes.io/name: syncthing
    spec:
      securityContext:
        runAsUser: {{ nonroot_uid }}
        # Primary GID is the shared NFS users group rather than nonroot_uid
        # because this pod writes to an NFS-backed PVC (/var/syncthing/data).
        # The NFSv4 server here does not honor supplemental groups for
        # permission checks — only the process's primary gid matches the
        # NFS export's group ownership, so runAsGroup must equal nfs_group_gid.
        runAsGroup: {{ nfs_group_gid }}
        runAsNonRoot: true
        fsGroup: {{ nfs_group_gid }}
        seccompProfile:
          type: RuntimeDefault
      initContainers:
        - name: configure-syncthing
          image: '{{ syncthing_image }}:{{ syncthing_image_tag }}'
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          command:
            - sh
            - -c
            - |
              CONFIG_FILE="/var/syncthing/config/config.xml"
              if [ ! -f "$CONFIG_FILE" ]; then
                  /bin/syncthing generate --home=/var/syncthing/config
              fi

              INSECURE="{{ syncthing_allow_insecure_admin_access | lower }}"
              if grep -q "<insecureAdminAccess>" "$CONFIG_FILE"; then
                  sed -i "s|<insecureAdminAccess>.*<\/insecureAdminAccess>|<insecureAdminAccess>${INSECURE}<\/insecureAdminAccess>|g" "$CONFIG_FILE"
              else
                  sed -i "/<gui /a \        <insecureAdminAccess>${INSECURE}</insecureAdminAccess>" "$CONFIG_FILE"
              fi

              DEFAULT_PATH="{{ syncthing_default_folder_path }}"
              if grep -q "<defaultFolderPath>" "$CONFIG_FILE"; then
                  sed -i "s|<defaultFolderPath>.*<\/defaultFolderPath>|<defaultFolderPath>${DEFAULT_PATH}<\/defaultFolderPath>|g" "$CONFIG_FILE"
              else
                  sed -i "/<options>/a \        <defaultFolderPath>${DEFAULT_PATH}</defaultFolderPath>" "$CONFIG_FILE"
              fi

              # Syncthing stores this as repeated singular <alwaysLocalNet>
              # elements inside <options>, not a plural wrapper.
              ALWAYS_LOCAL="{{ syncthing_always_local_nets }}"
              sed -i "/<alwaysLocalNets>.*<\/alwaysLocalNets>/d" "$CONFIG_FILE"
              if grep -q "<alwaysLocalNet>" "$CONFIG_FILE"; then
                  sed -i "s|<alwaysLocalNet>.*<\/alwaysLocalNet>|<alwaysLocalNet>${ALWAYS_LOCAL}<\/alwaysLocalNet>|g" "$CONFIG_FILE"
              else
                  sed -i "/<options>/a \        <alwaysLocalNet>${ALWAYS_LOCAL}</alwaysLocalNet>" "$CONFIG_FILE"
              fi

              # Ensure the default sync directory exists and is group-writable.
              # chmod is best-effort: under the restricted PSA profile the pod
              # cannot chmod paths it does not own, but the NFS export is
              # already created 2775 by infrastructure/nfs.yml.
              mkdir -p "$DEFAULT_PATH"
              chmod 2775 "$DEFAULT_PATH" 2>/dev/null || true
          volumeMounts:
            - name: syncthing-data
              mountPath: /var/syncthing
            - name: syncthing-nfs-data
              mountPath: /var/syncthing/data
            - name: tmp
              mountPath: /tmp
      containers:
        - name: syncthing
          image: '{{ syncthing_image }}:{{ syncthing_image_tag }}'
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          ports:
            - name: http
              containerPort: {{ syncthing_gui_port }}
              protocol: TCP
            - name: tcp-sync
              containerPort: {{ syncthing_sync_port }}
              protocol: TCP
            - name: udp-sync
              containerPort: {{ syncthing_sync_port }}
              protocol: UDP
            - name: discovery
              containerPort: {{ syncthing_discovery_port }}
              protocol: UDP
          volumeMounts:
            - name: syncthing-data
              mountPath: /var/syncthing
            - name: syncthing-nfs-data
              mountPath: /var/syncthing/data
            - name: tmp
              mountPath: /tmp
          readinessProbe:
            tcpSocket:
              port: {{ syncthing_gui_port }}
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            tcpSocket:
              port: {{ syncthing_gui_port }}
            initialDelaySeconds: 15
            periodSeconds: 20
      volumes:
        - name: syncthing-nfs-data
          persistentVolumeClaim:
            claimName: syncthing-nfs-data
        - name: tmp
          emptyDir: {}
  volumeClaimTemplates:
    - metadata:
        name: syncthing-data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: '{{ syncthing_storage_class }}'
        resources:
          requests:
            storage: '{{ syncthing_storage_size }}'
