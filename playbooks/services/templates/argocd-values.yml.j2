{#
  Helm values for the ArgoCD GitOps continuous delivery tool.

  ArgoCD is configured to run in insecure mode since TLS is terminated at the
  Traefik gateway. The built-in ingress is disabled in favour of a Gateway API
  HTTPRoute managed by authentication.yml.

  Authentik is wired as the OIDC provider so users sign in with their Authentik
  credentials. The OIDC client secret is stored in argocd-secret via the
  configs.secret.extra map and referenced in the oidc.config block using the
  $oidc.<name>.<key> substitution syntax so the plaintext secret is never
  written to the argocd-cm ConfigMap.

  The homelab CA certificate is injected in two places: as the rootCA field
  inside the OIDC configuration block so ArgoCD can verify Authentik's
  self-signed wildcard certificate during OIDC discovery and token exchange,
  and in the configs.tls.certificates map so the repository server trusts the
  homelab CA when connecting to Git servers that use the same certificate.

  RBAC grants read-only access to all authenticated users by default. Adjust
  the policy.csv rule to map Authentik group names to ArgoCD roles as needed.
  The group name must match the Authentik group name exactly. Group membership
  is delivered via the groups claim, which requires a groups scope mapping to
  be configured in Authentik and assigned to the ArgoCD OAuth2 provider.

  Dex is disabled since ArgoCD is configured to use Authentik directly via
  oidc.config. Running Dex alongside a direct OIDC configuration is redundant.

  The initial admin password is auto-generated by ArgoCD and stored in the
  argocd-initial-admin-secret Secret. Retrieve it with:
    kubectl get secret argocd-initial-admin-secret -n argocd \
      -o jsonpath='{.data.password}' | base64 -d

  Variables:
    argocd_hostname:           FQDN for the ArgoCD web UI
                               (e.g. argocd.homelab.internal).
    authentik_hostname:        FQDN for the Authentik UI, used to construct
                               the OIDC issuer URL.
    argocd_oidc_client_id:     OAuth2 client ID from the Authentik provider.
                               Fetched from the Authentik API by the playbook.
    argocd_oidc_client_secret: OAuth2 client secret from the Authentik
                               provider. Fetched from the Authentik API by
                               the playbook.
    cluster_ca_cert:           PEM-encoded cluster CA certificate. Read from
                               the wildcard-tls Secret in kube-system by the
                               playbook.
#}
global:
  domain: '{{ argocd_hostname }}'

dex:
  enabled: false

server:
  extraArgs:
    - --insecure

configs:
  cm:
    url: 'https://{{ argocd_hostname }}'
    oidc.config: |
      name: Authentik
      issuer: https://{{ authentik_hostname }}/application/o/argocd/
      clientID: {{ argocd_oidc_client_id }}
      clientSecret: $oidc.authentik.clientSecret
      rootCA: |
        {{ cluster_ca_cert | indent(8) }}
      requestedScopes:
        - openid
        - profile
        - email
        - groups

  secret:
    extra:
      oidc.authentik.clientSecret: '{{ argocd_oidc_client_secret }}'

  rbac:
    policy.default: role:readonly
    policy.csv: |
      g, authentik Admins, role:admin

  tls:
    certificates:
      homelab-ca.crt: |
        {{ cluster_ca_cert | indent(8) }}
