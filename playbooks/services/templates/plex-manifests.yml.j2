{#
  Native Kubernetes manifests for Plex Media Server, deployed via ArgoCD.
  Contains two PersistentVolumeClaims (config and media), a ClusterIP Service
  on port 32400, and a Deployment that runs the official Plex Media Server
  container.

  The Plex claim token is injected from the plex-credentials Kubernetes Secret
  (provisioned by plex.yml) via secretKeyRef. The claim token is consumed on
  first startup to bind the server to a plex.tv account; if the server is
  already claimed the token is ignored. Leave the secret's claim-token field
  empty if initial setup will be performed via the Plex web UI instead.

  Plex authenticates users via plex.tv accounts natively and does not support
  OIDC. The HTTPRoute is therefore applied without Traefik ForwardAuth so that
  native Plex clients (mobile, desktop, TV apps) are not blocked.

  Variables:
    plex_namespace:           Kubernetes namespace where Plex is deployed.
    plex_image:               Container image for Plex Media Server.
    plex_image_tag:           Container image tag for Plex Media Server.
    plex_config_storage_size: Size of the PVC for Plex configuration and metadata.
    plex_media_storage_size:  Size of the PVC for media files.
    plex_storage_class:       StorageClass to use for both PVCs.
    plex_timezone:            Timezone for the Plex container (e.g. America/Chicago).
    plex_port:                Port Plex listens on (default: 32400).
    plex_hostname:            Fully qualified hostname for the Plex web UI HTTPRoute.
    plex_server_hostname:     Fully qualified hostname for the native client LoadBalancer
                              service, registered in DNS via ExternalDNS.
    plex_lan_cidr:            LAN subnet CIDR used by the ingress NetworkPolicy to
                              restrict direct port access to local clients only.
#}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: plex-config
  namespace: '{{ plex_namespace }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: '{{ plex_storage_class }}'
  resources:
    requests:
      storage: '{{ plex_config_storage_size }}'
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: plex-media
  namespace: '{{ plex_namespace }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: '{{ plex_storage_class }}'
  resources:
    requests:
      storage: '{{ plex_media_storage_size }}'
---
apiVersion: v1
kind: Service
metadata:
  name: plex
  namespace: '{{ plex_namespace }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: plex
  ports:
    - name: http
      port: {{ plex_port }}
      targetPort: {{ plex_port }}
      protocol: TCP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: plex
  namespace: '{{ plex_namespace }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: plex
  template:
    metadata:
      labels:
        app.kubernetes.io/name: plex
    spec:
      containers:
        - name: plex
          image: '{{ plex_image }}:{{ plex_image_tag }}'
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ plex_port }}
              protocol: TCP
          env:
            - name: TZ
              value: '{{ plex_timezone }}'
            - name: PLEX_CLAIM
              valueFrom:
                secretKeyRef:
                  name: plex-credentials
                  key: claim-token
          volumeMounts:
            - name: config
              mountPath: /config
            - name: media
              mountPath: /data
          readinessProbe:
            tcpSocket:
              port: {{ plex_port }}
            initialDelaySeconds: 15
            periodSeconds: 10
          livenessProbe:
            tcpSocket:
              port: {{ plex_port }}
            initialDelaySeconds: 30
            periodSeconds: 20
      volumes:
        - name: config
          persistentVolumeClaim:
            claimName: plex-config
        - name: media
          persistentVolumeClaim:
            claimName: plex-media
---
apiVersion: v1
kind: Service
metadata:
  name: plex-direct
  namespace: '{{ plex_namespace }}'
  annotations:
    external-dns.alpha.kubernetes.io/hostname: '{{ plex_server_hostname }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: plex
  ports:
    - name: plex
      port: {{ plex_port }}
      targetPort: {{ plex_port }}
      protocol: TCP
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: plex-direct-ingress
  namespace: '{{ plex_namespace }}'
  labels:
    app.kubernetes.io/name: plex
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: plex
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: traefik
      ports:
        - port: {{ plex_port }}
          protocol: TCP
    - from:
        - ipBlock:
            cidr: '{{ plex_lan_cidr }}'
      ports:
        - port: {{ plex_port }}
          protocol: TCP
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: plex
  namespace: '{{ plex_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ plex_hostname }}'
  rules:
    - backendRefs:
        - name: plex
          namespace: '{{ plex_namespace }}'
          port: {{ plex_port }}
