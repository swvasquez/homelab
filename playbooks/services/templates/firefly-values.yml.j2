{#
  Firefly III Helm values for the homelab deployment. Deployed by ArgoCD using the
  multi-source feature, with this file stored in the Gitea gitops repository and
  the Firefly III Helm chart sourced from the upstream repository.

  PostgreSQL is provided by a CloudNativePG Cluster (firefly-db) provisioned by the
  firefly.yml Ansible playbook. The database password and Laravel APP_KEY are loaded
  from the firefly-credentials Kubernetes Secret via config.existingSecret so that they
  are never committed to the gitops repository. The secret must contain keys named
  APP_KEY and DB_PASSWORD.

  The bundled Bitnami postgresql subchart is disabled in favour of the cnpg-managed
  database. Ingress is disabled in favour of a Traefik HTTPRoute with Authentik
  ForwardAuth, managed by cluster/authentication.yml.

  Note: MAIL_MAILER is set to 'log' to suppress mail delivery errors in a homelab
  environment where no SMTP server is configured.

  Note: live currency exchange rate fetching is blocked by the egress NetworkPolicy
  applied by firefly.yml. The cron job will log an error for the exchange rate task
  but all other scheduled tasks will continue to run normally.

  The pod runs as the image's built-in www-data user (UID/GID 33). Setting
  runAsUser to nonroot_uid (65532) causes the entrypoint to fail writing to
  /etc/nginx/nginx.conf (owned by root, writable only by the image user). PSA
  restricted accepts UID 33 because runAsNonRoot only requires a non-zero UID.
  runAsUser must be set explicitly as a number because the image declares USER
  as the string 'www-data' — without a numeric runAsUser, Kubernetes cannot
  verify runAsNonRoot and rejects the pod with CreateContainerConfigError.
  fsGroup is set to 33 so www-data can write to the uploads PVC. The cronjob
  uses curlimages/curl which supports nonroot_uid directly.

  Variables:
    dns_zone:                 DNS zone used to derive the APP_URL (e.g. homelab.internal).
    firefly_namespace:        Kubernetes namespace where Firefly III is deployed.
    firefly_db_name:          PostgreSQL database name.
    firefly_db_username:      PostgreSQL username.
    firefly_storage_class:    Kubernetes StorageClass for the uploads PVC.
    firefly_storage_size:     Size of the uploads PVC.
    firefly_app_key_pinned:   Exactly 32-character key for the chart-managed
                              firefly-iii-app-key Secret. Read from the existing
                              firefly-iii-app-key Secret if present, otherwise generated
                              with openssl rand -hex 16. Pinned via secrets.appKey to
                              prevent the Helm chart from calling randAlphaNum on each
                              render, which would cause perpetual OutOfSync in ArgoCD.
#}
secrets:
  appKey: '{{ firefly_app_key_pinned }}'

config:
  env:
    APP_URL: 'https://firefly.{{ dns_zone }}'
    DB_CONNECTION: pgsql
    DB_HOST: 'firefly-db-rw.{{ firefly_namespace }}.svc'
    DB_PORT: '5432'
    DB_DATABASE: '{{ firefly_db_name }}'
    DB_USERNAME: '{{ firefly_db_username }}'
    MAIL_MAILER: log
    TRUSTED_PROXIES: '**'
  existingSecret: firefly-credentials

podSecurityContext:
  runAsNonRoot: true
  runAsUser: 33
  runAsGroup: 33
  fsGroup: 33
  seccompProfile:
    type: RuntimeDefault

# readOnlyRootFilesystem is intentionally not set on this chart.
# The fireflyiii/core image is built on serversideup/php which runs
# s6-overlay plus a numbered chain of /etc/entrypoint.d/*.sh init scripts
# at startup. Those scripts render templates straight into /etc/nginx
# (and other rootfs paths), so just enabling S6_READ_ONLY_ROOT=1 plus
# emptyDirs at /run, /var/log, /var/cache, and /tmp is not enough — the
# very first entrypoint step (10-init-webserver-config.sh) fails with
# 'cannot create /etc/nginx/nginx.conf: Read-only file system'.
# Mounting an emptyDir at /etc/nginx would shadow the templates the
# entrypoint reads from, and the firefly-iii Helm chart does not expose
# initContainers, so there is no clean way to seed those templates into
# a writable volume before the main container starts.
# The firefly-iii namespace is therefore listed in the NotIn exclusion
# list of the require-readonly-rootfs Kyverno ClusterPolicy
# (playbooks/cluster/templates/kyverno-policies/require-readonly-rootfs.yml.j2).
# Revisit when the upstream image supports a true read-only mode or the
# chart adds initContainer hooks.
securityContext:
  allowPrivilegeEscalation: false
  capabilities:
    drop:
      - ALL

persistence:
  enabled: true
  storageClassName: '{{ firefly_storage_class }}'
  storage: '{{ firefly_storage_size }}'
  accessMode: ReadWriteOnce

cronjob:
  enabled: true
  podSecurityContext:
    runAsNonRoot: true
    runAsUser: {{ nonroot_uid }}
    runAsGroup: {{ nonroot_uid }}
    fsGroup: {{ nonroot_uid }}
    seccompProfile:
      type: RuntimeDefault
  securityContext:
    allowPrivilegeEscalation: false
    capabilities:
      drop:
        - ALL

importer:
  enabled: false

ingress:
  enabled: false

postgresql:
  enabled: false
