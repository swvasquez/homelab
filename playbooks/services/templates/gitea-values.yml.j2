{#
  Helm values for the Gitea self-hosted Git service.

  Configures Gitea with auto-generated admin and PostgreSQL credentials, and
  wires Authentik as the OIDC provider so users sign in via Authentik. Local
  account registration is disabled — all accounts are provisioned on first
  OIDC login. The built-in ingress is disabled in favour of a Gateway API
  HTTPRoute managed by authentication.yml.

  PostgreSQL is provided by a CloudNativePG Cluster managed outside this chart,
  so both the bundled postgresql and postgresql-ha subcharts are disabled. The
  legacy redis-cluster subchart is also disabled; Gitea uses the valkey-cluster
  subchart for caching and queue storage.

  All pods in this chart (Gitea main, its init containers, and the Valkey
  cluster) run as the shared non-root UID/GID defined by `nonroot_uid` in
  group_vars. Pod- and container-level security contexts satisfy the Pod
  Security Admission `restricted` profile enforced on the gitea namespace.

  The homelab-ca ConfigMap (created by the playbook from the wildcard-tls
  Secret in kube-system) is injected before Gitea's own init containers run.
  A preExtraInitContainer combines the Alpine system CA bundle with the
  homelab CA so that Gitea trusts the cluster's self-signed wildcard
  certificate when fetching the Authentik OIDC discovery document. This
  preExtraInitContainer is rendered verbatim by the chart, so its
  securityContext is declared inline to keep it restricted-compliant.

  Variables:
    gitea_admin_password:     Gitea admin account password. Read from the
                              gitea-credentials Kubernetes Secret.
    admin_email:              Email address for the Gitea admin account.
                              Read from group_vars.
    gitea_postgres_password:  Password for the Gitea PostgreSQL user. Read
                              from the gitea-credentials Kubernetes Secret.
    gitea_hostname:           FQDN for the Gitea web UI
                              (e.g. gitea.homelab.internal).
    gitea_ssh_hostname:       FQDN for the Gitea SSH LoadBalancer service.
                              Used in clone URLs and ExternalDNS annotation
                              (e.g. gitea-ssh.homelab.internal).
    gitea_ssh_port:           External port for the SSH LoadBalancer service.
                              Derived from ufw_allowed_ports.gitea_ssh.port.
    authentik_hostname:       FQDN for the Authentik UI, used to construct
                              the OIDC discovery and icon URLs.
    gitea_oidc_client_id:     OAuth2 client ID from the Authentik provider.
                              Fetched from the Authentik API by the playbook.
    gitea_oidc_client_secret: OAuth2 client secret from the Authentik provider.
                              Fetched from the Authentik API by the playbook.
    nonroot_uid:              Shared non-root UID and GID for every pod in the
                              gitea namespace. Read from group_vars.
#}
gitea:
  admin:
    username: gitea_admin
    password: '{{ gitea_admin_password }}'
    email: '{{ admin_email }}'

  config:
    database:
      DB_TYPE: postgres
      HOST: 'gitea-db-rw.gitea.svc:5432'
      NAME: gitea
      USER: gitea
      PASSWD: '{{ gitea_postgres_password }}'
    server:
      DOMAIN: '{{ gitea_hostname }}'
      ROOT_URL: 'https://{{ gitea_hostname }}'
      SSH_DOMAIN: '{{ gitea_ssh_hostname }}'
      SSH_PORT: '{{ gitea_ssh_port }}'
    service:
      DISABLE_REGISTRATION: false
      ALLOW_ONLY_EXTERNAL_REGISTRATION: true

  oauth:
    - name: Authentik
      provider: openidConnect
      key: '{{ gitea_oidc_client_id }}'
      secret: '{{ gitea_oidc_client_secret }}'
      autoDiscoverUrl: >-
        https://{{ authentik_hostname }}/application/o/gitea/.well-known/openid-configuration
      iconUrl: 'https://{{ authentik_hostname }}/static/dist/assets/icons/icon.png'
      scopes: openid email profile

# Applied to the gitea Deployment pod and propagated by the chart to the
# built-in init containers (init-directories, init-app-ini, configure-gitea)
# via containerSecurityContext. fsGroupChangePolicy: Always forces the kubelet
# to recursively chown the data PVC at mount time, which is required for the
# one-time UID migration from 1000 to {{ nonroot_uid }}.
podSecurityContext:
  runAsUser: {{ nonroot_uid }}
  runAsGroup: {{ nonroot_uid }}
  runAsNonRoot: true
  fsGroup: {{ nonroot_uid }}
  fsGroupChangePolicy: Always
  seccompProfile:
    type: RuntimeDefault

containerSecurityContext:
  runAsUser: {{ nonroot_uid }}
  runAsGroup: {{ nonroot_uid }}
  runAsNonRoot: true
  allowPrivilegeEscalation: false
  capabilities:
    drop: ['ALL']
  seccompProfile:
    type: RuntimeDefault

postgresql:
  enabled: false

postgresql-ha:
  enabled: false

redis-cluster:
  enabled: false

# Overrides the Bitnami valkey-cluster subchart defaults so the pods run under
# the shared {{ nonroot_uid }} UID/GID and satisfy PSA `restricted`. The chart's
# default containerSecurityContext already sets allowPrivilegeEscalation,
# capabilities, runAsNonRoot and seccompProfile, but overriding the map
# replaces it entirely, so every field must be repeated here.
# readOnlyRootFilesystem is preserved from the chart default.
valkey-cluster:
  podSecurityContext:
    runAsUser: {{ nonroot_uid }}
    runAsGroup: {{ nonroot_uid }}
    runAsNonRoot: true
    fsGroup: {{ nonroot_uid }}
    fsGroupChangePolicy: Always
    seccompProfile:
      type: RuntimeDefault
  containerSecurityContext:
    runAsUser: {{ nonroot_uid }}
    runAsGroup: {{ nonroot_uid }}
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    readOnlyRootFilesystem: true
    capabilities:
      drop: ['ALL']
    seccompProfile:
      type: RuntimeDefault

persistence:
  enabled: true
  storageClass: longhorn
  size: 10Gi

ingress:
  enabled: false

service:
  http:
    type: ClusterIP
    port: 3000
  ssh:
    type: LoadBalancer
    port: {{ gitea_ssh_port }}
    annotations:
      external-dns.alpha.kubernetes.io/hostname: '{{ gitea_ssh_hostname }}'

# Combines the Alpine system CA bundle with the homelab self-signed CA so that
# Gitea trusts the cluster wildcard certificate. A preExtraInitContainer writes
# the combined bundle to an EmptyDir which is then mounted over the default CA
# bundle path in all Gitea containers.
preExtraInitContainers:
  - name: inject-homelab-ca
    image: alpine:3
    command:
      - sh
      - -c
      - 'cat /etc/ssl/certs/ca-certificates.crt /homelab-ca/ca.crt > /combined-ca/ca-certificates.crt'
    securityContext:
      runAsUser: {{ nonroot_uid }}
      runAsGroup: {{ nonroot_uid }}
      runAsNonRoot: true
      allowPrivilegeEscalation: false
      capabilities:
        drop: ['ALL']
      seccompProfile:
        type: RuntimeDefault
    volumeMounts:
      - name: homelab-ca
        mountPath: /homelab-ca
        readOnly: true
      - name: combined-ca
        mountPath: /combined-ca

extraVolumes:
  - name: homelab-ca
    configMap:
      name: homelab-ca
  - name: combined-ca
    emptyDir: {}

extraInitVolumeMounts:
  - name: combined-ca
    mountPath: /etc/ssl/certs/ca-certificates.crt
    subPath: ca-certificates.crt

extraContainerVolumeMounts:
  - name: combined-ca
    mountPath: /etc/ssl/certs/ca-certificates.crt
    subPath: ca-certificates.crt
