{#
  ArgoCD Application manifest for the Open WebUI deployment. Uses the multi-source
  feature to pull the Open WebUI Helm chart from the upstream chart repository while
  reading the Helm values file from the Gitea gitops repository. Any push to the
  gitops repository triggers an immediate sync via the Gitea webhook registered
  by argocd.yml.

  Variables:
    argocd_namespace:         Kubernetes namespace where ArgoCD is deployed.
    openwebui_namespace:      Kubernetes namespace where Open WebUI will be deployed.
    openwebui_chart_version:  Helm chart version of Open WebUI to deploy.
    openwebui_gitops_path:    Path within the gitops repository to the Open WebUI
                              values file (e.g. apps/open-webui).
    gitea_namespace:          Kubernetes namespace where Gitea is deployed.
    gitea_admin_username:     Gitea admin username that owns the gitops repository.
    gitea_gitops_repo:        Name of the Gitea gitops repository.
#}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: open-webui
  namespace: '{{ argocd_namespace }}'
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  sources:
    - repoURL: https://helm.openwebui.com/
      chart: open-webui
      targetRevision: '{{ openwebui_chart_version }}'
      helm:
        releaseName: open-webui
        valueFiles:
          - '$values/{{ openwebui_gitops_path }}/values.yml'
    - repoURL: 'http://gitea-http.{{ gitea_namespace }}.svc.cluster.local:3000/{{ gitea_admin_username }}/{{ gitea_gitops_repo }}'
      targetRevision: HEAD
      ref: values
  destination:
    server: https://kubernetes.default.svc
    namespace: '{{ openwebui_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
