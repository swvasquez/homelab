{#
  ArgoCD Application manifest for Plex Media Server. Tracks the native
  Kubernetes manifests committed to the Gitea gitops repository by plex.yml.
  Any push to the gitops repository triggers an immediate sync via the Gitea
  webhook registered by argocd.yml.

  Variables:
    argocd_namespace:       Kubernetes namespace where ArgoCD is deployed.
    plex_namespace:         Kubernetes namespace where Plex will be deployed.
    plex_gitops_path:       Path within the gitops repository to the Plex manifests.
    gitea_namespace:        Kubernetes namespace where Gitea is deployed.
    gitea_admin_username:   Gitea admin username that owns the gitops repository.
    gitea_gitops_repo:      Name of the Gitea gitops repository.
#}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: plex
  namespace: '{{ argocd_namespace }}'
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: >-
      http://gitea-http.{{ gitea_namespace }}.svc.cluster.local:3000/{{ gitea_admin_username
      }}/{{ gitea_gitops_repo }}
    path: '{{ plex_gitops_path }}'
    targetRevision: main
  destination:
    server: https://kubernetes.default.svc
    namespace: '{{ plex_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
