{#
  Generic ExternalSecret manifest for the External Secrets Operator. Defines
  a declarative pointer that ESO uses to fetch a secret from the configured
  ClusterSecretStore (default: openbao) and materialize it as a regular
  Kubernetes Secret in the target namespace. Each entry in es_data maps one
  field of the remote OpenBao KV secret to a key in the resulting K8s
  Secret.

  Variables:
    es_name:               Name of the ExternalSecret resource.
    es_namespace:          Namespace where the ExternalSecret (and the
                           materialized K8s Secret) live.
    es_target_secret_name: Name of the K8s Secret ESO will create from the
                           remote data.
    es_data:               List of mappings, each a dict with keys:
                             secret_key      — destination key on the K8s
                                               Secret.
                             remote_key      — KV path under the store's
                                               base path (e.g. for the
                                               'openbao' store rooted at
                                               'secret/', a remote_key of
                                               'authentik/bootstrap_password'
                                               resolves to
                                               'secret/data/authentik/bootstrap_password').
                             remote_property — JSON property within the KV
                                               value document to read.
    es_refresh_interval:   (Optional) ESO poll interval. Default 1h.
    es_store_name:         (Optional) ClusterSecretStore name to read from.
                           Default 'openbao'.
#}
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: '{{ es_name }}'
  namespace: '{{ es_namespace }}'
spec:
  refreshInterval: '{{ es_refresh_interval | default("1h") }}'
  secretStoreRef:
    kind: ClusterSecretStore
    name: '{{ es_store_name | default("openbao") }}'
  target:
    name: '{{ es_target_secret_name }}'
  data:
{% for d in es_data %}
    - secretKey: '{{ d.secret_key }}'
      remoteRef:
        key: '{{ d.remote_key }}'
        property: '{{ d.remote_property }}'
{% endfor %}
