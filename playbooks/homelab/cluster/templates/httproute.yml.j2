{#
  Defines a generic HTTPRoute that exposes a UI or API over the LAN via the
  traefik-gateway. Routes HTTPS traffic matching the specified hostname to the
  specified backend service. HTTP traffic is redirected to HTTPS by the Traefik
  entrypoint redirect configured in traefik-values.yml.j2 — no per-route HTTP
  redirect is needed.

  If httproute_backend_namespace is specified and differs from httproute_namespace,
  a ReferenceGrant is automatically included in the backend namespace to allow the
  HTTPRoute to reference the service across namespace boundaries.

  When with_forward_auth is true, the Authentik ForwardAuth middleware is applied
  to the route, requiring authentication before the request reaches the backend.
  The authentik-forward-auth Middleware must be deployed to the same namespace
  as the HTTPRoute (httproute_namespace) before enabling this.

  Variables:
    httproute_name:              Name of the HTTPRoute resource.
    httproute_namespace:         Kubernetes namespace where the HTTPRoute is deployed.
    httproute_hostname:          Fully qualified hostname for the route
                                 (e.g. app.homelab.internal).
    httproute_backend_name:      Name of the backend Service to route traffic to.
    httproute_backend_port:      Port of the backend Service.
    httproute_backend_namespace: Kubernetes namespace of the backend Service.
    with_forward_auth:           (Optional) When true, applies the authentik-forward-auth
                                 Middleware to the route (default: false).
#}
{% if httproute_backend_namespace != httproute_namespace %}
apiVersion: gateway.networking.k8s.io/v1beta1
kind: ReferenceGrant
metadata:
  name: {{ httproute_name }}-grant
  namespace: '{{ httproute_backend_namespace }}'
spec:
  from:
    - group: gateway.networking.k8s.io
      kind: HTTPRoute
      namespace: '{{ httproute_namespace }}'
  to:
    - group: ''
      kind: Service
---
{% endif %}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: '{{ httproute_name }}'
  namespace: '{{ httproute_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ httproute_hostname }}'
  rules:
    - backendRefs:
        - name: '{{ httproute_backend_name }}'
          namespace: '{{ httproute_backend_namespace }}'
          port: {{ httproute_backend_port }}
{% if with_forward_auth | default(false) %}
      filters:
        - type: ExtensionRef
          extensionRef:
            group: traefik.io
            kind: Middleware
            name: authentik-forward-auth
{% endif %}
