{#
  Defines the kubeadm InitConfiguration and ClusterConfiguration used to initialize
  the Kubernetes control plane. Written to a temporary file on the bootstrap node
  and passed to `kubeadm init --config`.

  Variables:
    kubeadm_cri_socket:      CRI socket path (e.g. unix:///var/run/cri-dockerd.sock).
    cluster_name:            Name of the Kubernetes cluster (e.g. homelab-0).
    pod_network_cidr:        CIDR range for pod networking (e.g. 10.244.0.0/16).
    kubernetes_api_hostname: DNS hostname registered as a Subject Alternative Name
                             on the kube-apiserver serving certificate so kubectl
                             can address the API by name in addition to node IP.
#}
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
nodeRegistration:
  criSocket: '{{ kubeadm_cri_socket }}'
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
clusterName: '{{ cluster_name }}'
networking:
  podSubnet: '{{ pod_network_cidr }}'
apiServer:
  certSANs:
    - '{{ kubernetes_api_hostname }}'
