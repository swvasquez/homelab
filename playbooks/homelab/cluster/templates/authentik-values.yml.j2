{#
  Helm values for the Authentik identity provider.

  Configures the authentik chart with the auto-generated credentials from the
  authentik-credentials Kubernetes Secret. PostgreSQL and Redis subcharts are
  enabled to provide persistent storage and caching within the cluster.

  The bootstrap_token sets AUTHENTIK_BOOTSTRAP_TOKEN, which creates a persistent
  API token in the Authentik database on first run. This token is used by the
  authentication.yml playbook to configure Authentik via the REST API without
  requiring manual UI interaction.

  The bootstrap_email sets the default admin account email on first run via
  AUTHENTIK_BOOTSTRAP_EMAIL. On subsequent runs this value is ignored by
  Authentik if the account already exists.

  The namespace runs under Pod Security Admission 'restricted'. The server and
  worker pods each carry a full restricted securityContext via the chart's
  per-component `securityContext` (pod level) and `containerSecurityContext`
  (container level) keys, and run as nonroot_uid (65532). The authentik image
  declares `USER authentik` (UID 1000) in its Dockerfile, but Kubernetes cannot
  verify `runAsNonRoot` against a USER name alone — a numeric runAsUser is
  required, so it is set explicitly here. If a future image change makes UID
  65532 incompatible (e.g. hardcoded writes to /authentik paths owned by
  UID 1000), fall back to runAsUser/runAsGroup/fsGroup = 1000 to match the
  image's baked-in user; PSA restricted accepts either UID because it checks
  runAsNonRoot, not a specific value.

  The CloudNativePG authentik-db pod is not configured here — it lives on the
  operator's own defaults (UID 26) and is already restricted-compliant.

  Variables:
    authentik_secret_key:        Django secret key for Authentik. Read from the
                                 authentik-credentials Kubernetes Secret.
    authentik_postgres_password: Password for the Authentik PostgreSQL user.
                                 Read from the authentik-credentials Kubernetes Secret.
    authentik_bootstrap_token:   API token created on first run. Read from the
                                 authentik-credentials Kubernetes Secret.
    admin_email:                 Email address for the default admin account.
                                 Read from group_vars.
    bootstrap_admin_password:    Initial password for the default admin account.
                                 Read from group_vars.
    nonroot_uid:                 Shared non-root UID for the authentik server
                                 and worker pods. Read from group_vars.
#}
authentik:
  secret_key: '{{ authentik_secret_key }}'
  postgresql:
    host: authentik-db-rw.authentik.svc
    port: 5432
    name: authentik
    user: authentik
    password: '{{ authentik_postgres_password }}'
  bootstrap_token: '{{ authentik_bootstrap_token }}'
  bootstrap_email: '{{ admin_email }}'
  bootstrap_password: '{{ bootstrap_admin_password }}'

server:
  securityContext:
    runAsNonRoot: true
    runAsUser: {{ nonroot_uid }}
    runAsGroup: {{ nonroot_uid }}
    fsGroup: {{ nonroot_uid }}
    seccompProfile:
      type: RuntimeDefault
  containerSecurityContext:
    allowPrivilegeEscalation: false
    readOnlyRootFilesystem: true
    capabilities:
      drop:
        - ALL
  volumes:
    - name: tmp
      emptyDir: {}
  volumeMounts:
    - name: tmp
      mountPath: /tmp

worker:
  securityContext:
    runAsNonRoot: true
    runAsUser: {{ nonroot_uid }}
    runAsGroup: {{ nonroot_uid }}
    fsGroup: {{ nonroot_uid }}
    seccompProfile:
      type: RuntimeDefault
  containerSecurityContext:
    allowPrivilegeEscalation: false
    readOnlyRootFilesystem: true
    capabilities:
      drop:
        - ALL
  volumes:
    - name: tmp
      emptyDir: {}
  volumeMounts:
    - name: tmp
      mountPath: /tmp

postgresql:
  enabled: false

redis:
  enabled: true
