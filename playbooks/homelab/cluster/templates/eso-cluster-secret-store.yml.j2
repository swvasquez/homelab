{#
  Cluster-scoped SecretStore that points ESO at the in-cluster OpenBao
  service. ExternalSecret resources in any namespace can reference this
  by name. ESO connects via the ClusterIP service (not the LAN HTTPRoute)
  so the secret-fetch path stays inside the cluster and does not depend
  on Traefik or wildcard TLS.

  Authentication uses the kubernetes auth method enabled in OpenBao. ESO
  presents its own ServiceAccount token; OpenBao validates it via
  TokenReview and issues a short-lived OpenBao client token bound to the
  'eso' policy.

  Variables:
    eso_namespace:        Namespace where ESO's controller and SA run.
    openbao_namespace:    Namespace where the OpenBao service lives.
    openbao_service_name: Name of the OpenBao ClusterIP service the chart
                          created.
    eso_role:             Auth-method role name to ask for at login. Must
                          match the role created in OpenBao alongside
                          the 'eso' policy.
    eso_sa_name:          Name of ESO's controller ServiceAccount, the
                          identity OpenBao validates against the
                          bound_service_account_names configured on the
                          'eso' role.
#}
apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: openbao
spec:
  provider:
    vault:
      server: 'http://{{ openbao_service_name }}.{{ openbao_namespace }}.svc:8200'
      path: secret
      version: v2
      auth:
        kubernetes:
          mountPath: kubernetes
          role: '{{ eso_role }}'
          serviceAccountRef:
            name: '{{ eso_sa_name }}'
            namespace: '{{ eso_namespace }}'
