{#
  Defines the Kubernetes resources for the Bind9 authoritative DNS server:
    - ConfigMap (bind9-config): named.conf with TSIG key and zone configuration.
    - ConfigMap (bind9-zones):  Initial zone file for the homelab DNS zone.
    - PersistentVolumeClaim:    Stores zone data written by ExternalDNS across pod restarts.
    - Deployment:               Runs the Bind9 container with an initContainer that copies
                                the initial zone file to the PVC on first boot.
    - Service (LoadBalancer):   Exposes Bind9 on UDP and TCP with a dedicated
                                LAN IP from the Cilium IP pool.

  Variables:
    bind9_namespace:   Kubernetes namespace for Bind9 (e.g. kube-system).
    bind9_image:       Container image for Bind9 (e.g. internetsystemsconsortium/bind9:9.20).
    bind9_pvc_size:    Size of the PersistentVolumeClaim for zone data (e.g. 128Mi).
    bind9_tsig_secret: TSIG shared secret for RFC 2136 dynamic updates. Auto-generated
                       on first run and stored in the bind9-tsig Kubernetes Secret.
    bind9_dns_port:    Port Bind9 listens on for DNS queries (TCP and UDP).
                       Derived from ufw_allowed_ports.bind9_dns_tcp.port in group_vars.
    dns_zone:          DNS zone served by Bind9 (e.g. homelab.internal).
                       Read from group_vars.
#}
apiVersion: v1
kind: ConfigMap
metadata:
  name: bind9-config
  namespace: '{{ bind9_namespace }}'
data:
  named.conf: |
    options {
        directory "/var/cache/bind";
        listen-on { any; };
        listen-on-v6 { none; };
        allow-query { any; };
        recursion no;
        allow-transfer { key "externaldns-key"; };
        dnssec-validation no;
    };

    key "externaldns-key" {
        algorithm hmac-sha256;
        secret "{{ bind9_tsig_secret }}";
    };

    zone "{{ dns_zone }}" IN {
        type master;
        file "/var/lib/bind/db.{{ dns_zone }}";
        allow-update { key "externaldns-key"; };
    };
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: bind9-zones
  namespace: '{{ bind9_namespace }}'
data:
  db.{{ dns_zone }}: |
    $ORIGIN {{ dns_zone }}.
    $TTL 3600
    @   IN  SOA ns.{{ dns_zone }}. admin.{{ dns_zone }}. (
                1       ; Serial
                10800   ; Refresh
                3600    ; Retry
                604800  ; Expire
                3600    ; Negative Cache TTL
            )
    @   IN  NS  ns.{{ dns_zone }}.
    ns  IN  A   127.0.0.1
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: bind9-zone-data
  namespace: '{{ bind9_namespace }}'
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: '{{ bind9_pvc_size }}'
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: bind9
  namespace: '{{ bind9_namespace }}'
  labels:
    app: bind9
spec:
  replicas: 1
  selector:
    matchLabels:
      app: bind9
  template:
    metadata:
      labels:
        app: bind9
    spec:
      initContainers:
        - name: copy-zones
          image: busybox:1.37
          command:
            - sh
            - -c
            - cp -n /zones/* /var/lib/bind/ && chown -R 53:53 /var/lib/bind/
          volumeMounts:
            - name: zone-templates
              mountPath: /zones
            - name: zone-data
              mountPath: /var/lib/bind
      containers:
        - name: bind9
          image: '{{ bind9_image }}'
          ports:
            - containerPort: {{ bind9_dns_port }}
              protocol: UDP
            - containerPort: {{ bind9_dns_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /etc/bind/named.conf
              subPath: named.conf
            - name: zone-data
              mountPath: /var/lib/bind
          resources:
            limits:
              cpu: 250m
              memory: 256Mi
            requests:
              cpu: 50m
              memory: 64Mi
      volumes:
        - name: config
          configMap:
            name: bind9-config
        - name: zone-templates
          configMap:
            name: bind9-zones
        - name: zone-data
          persistentVolumeClaim:
            claimName: bind9-zone-data
---
apiVersion: v1
kind: Service
metadata:
  name: bind9
  namespace: '{{ bind9_namespace }}'
spec:
  type: LoadBalancer
  selector:
    app: bind9
  ports:
    - name: dns-udp
      port: {{ bind9_dns_port }}
      protocol: UDP
      targetPort: {{ bind9_dns_port }}
    - name: dns-tcp
      port: {{ bind9_dns_port }}
      protocol: TCP
      targetPort: {{ bind9_dns_port }}
