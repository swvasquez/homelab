{#
  Native Kubernetes manifests for the Vaultwarden deployment, deployed via ArgoCD.
  Contains a ConfigMap for the homelab CA certificate, the PersistentVolumeClaim
  for data storage, the ClusterIP Service, and the Deployment that runs the
  Vaultwarden container.

  The admin token, database URL, and OIDC client credentials are injected via
  secretKeyRef from Kubernetes Secrets provisioned by vaultwarden.yml:
    - vaultwarden-credentials  admin-token
    - vaultwarden-db-url       url (full PostgreSQL connection string)
    - vaultwarden-oidc         SSO_CLIENT_ID, SSO_CLIENT_SECRET

  The homelab CA certificate is mounted into the pod and SSL_CERT_FILE is set
  so that Vaultwarden's TLS client (reqwest/OpenSSL) trusts the self-signed
  wildcard certificate used by Authentik and other internal services.

  The pod runs as nonroot_uid (65532) under PSA restricted. ROCKET_PORT is set
  to 8080 so the process does not need NET_BIND_SERVICE to bind a privileged
  port. The Service keeps its external port at 80 and routes to targetPort 8080.

  Variables:
    dns_zone:                   DNS zone used to derive DOMAIN and SSO_AUTHORITY
                                (e.g. homelab.internal).
    vaultwarden_namespace:      Kubernetes namespace where Vaultwarden is deployed.
    vaultwarden_image:          Container image for Vaultwarden.
    vaultwarden_image_tag:      Container image tag for Vaultwarden.
    vaultwarden_storage_size:   Size of the data PVC.
    vaultwarden_storage_class:  Kubernetes StorageClass for the data PVC.
    homelab_ca_cert:            PEM-encoded CA certificate for homelab services.
                                Read from the wildcard-tls Secret by vaultwarden.yml.
    nonroot_uid:                Shared non-root UID/GID for pod and container
                                securityContext. Read from group_vars.
#}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: vaultwarden-ca
  namespace: '{{ vaultwarden_namespace }}'
  labels:
    app.kubernetes.io/name: vaultwarden
data:
  ca.crt: |
    {{ homelab_ca_cert | indent(4) }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: vaultwarden-data
  namespace: '{{ vaultwarden_namespace }}'
  labels:
    app.kubernetes.io/name: vaultwarden
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: '{{ vaultwarden_storage_class }}'
  resources:
    requests:
      storage: '{{ vaultwarden_storage_size }}'
---
apiVersion: v1
kind: Service
metadata:
  name: vaultwarden
  namespace: '{{ vaultwarden_namespace }}'
  labels:
    app.kubernetes.io/name: vaultwarden
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: vaultwarden
  ports:
    - name: http
      port: 80
      targetPort: 8080
      protocol: TCP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vaultwarden
  namespace: '{{ vaultwarden_namespace }}'
  labels:
    app.kubernetes.io/name: vaultwarden
  annotations:
    # Tell Stakater Reloader to roll this Deployment whenever any Secret
    # or ConfigMap referenced via env / envFrom / volume changes. Pairs
    # with the ExternalSecret resources in cluster/secrets.yml +
    # service/vaultwarden.yml so 'bao kv put secret/vaultwarden/...'
    # propagates end-to-end without manual rollouts.
    reloader.stakater.com/auto: 'true'
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vaultwarden
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vaultwarden
    spec:
      securityContext:
        runAsNonRoot: true
        runAsUser: {{ nonroot_uid }}
        runAsGroup: {{ nonroot_uid }}
        fsGroup: {{ nonroot_uid }}
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: vaultwarden
          image: '{{ vaultwarden_image }}:{{ vaultwarden_image_tag }}'
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          ports:
            - name: http
              containerPort: 8080
              protocol: TCP
          env:
            - name: ROCKET_PORT
              value: '8080'
            - name: DOMAIN
              value: 'https://vault.{{ dns_zone }}'
            - name: SIGNUPS_ALLOWED
              value: 'false'
            - name: SSO_ENABLED
              value: 'true'
            - name: SSO_AUTHORITY
              value: 'https://authentik.{{ dns_zone }}/application/o/vaultwarden-sso/'
            - name: ADMIN_TOKEN
              valueFrom:
                secretKeyRef:
                  name: vaultwarden-credentials
                  key: admin-token
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: vaultwarden-db-credentials
                  key: url
            - name: SSO_CLIENT_ID
              valueFrom:
                secretKeyRef:
                  name: vaultwarden-oidc
                  key: SSO_CLIENT_ID
            - name: SSO_CLIENT_SECRET
              valueFrom:
                secretKeyRef:
                  name: vaultwarden-oidc
                  key: SSO_CLIENT_SECRET
            - name: SSL_CERT_FILE
              value: /etc/ssl/certs/homelab-ca.crt
          volumeMounts:
            - name: data
              mountPath: /data
            - name: ca-cert
              mountPath: /etc/ssl/certs/homelab-ca.crt
              subPath: ca.crt
              readOnly: true
            - name: tmp
              mountPath: /tmp
          readinessProbe:
            httpGet:
              path: /alive
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /alive
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 20
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: vaultwarden-data
        - name: ca-cert
          configMap:
            name: vaultwarden-ca
        - name: tmp
          emptyDir: {}
