{#
  ArgoCD Application manifest for the Firefly III deployment. Uses the multi-source
  feature to pull the Firefly III Helm chart from the upstream chart repository while
  reading the Helm values file from the Gitea gitops repository. Any push to the
  gitops repository triggers an immediate sync via the Gitea webhook registered
  by argocd.yml.

  Variables:
    argocd_namespace:        Kubernetes namespace where ArgoCD is deployed.
    firefly_namespace:       Kubernetes namespace where Firefly III will be deployed.
    firefly_chart_version:   Helm chart version of Firefly III to deploy.
    firefly_gitops_path:     Path within the gitops repository to the Firefly III
                             values file (e.g. apps/firefly-iii).
    gitea_namespace:         Kubernetes namespace where Gitea is deployed.
    gitea_admin_username:    Gitea admin username that owns the gitops repository.
    gitea_gitops_repo:       Name of the Gitea gitops repository.
#}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: firefly-iii
  namespace: '{{ argocd_namespace }}'
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  sources:
    - repoURL: https://firefly-iii.github.io/kubernetes/
      chart: firefly-iii
      targetRevision: '{{ firefly_chart_version }}'
      helm:
        releaseName: firefly-iii
        valueFiles:
          - '$values/{{ firefly_gitops_path }}/values.yml'
    - repoURL: >-
        http://gitea-http.{{ gitea_namespace }}.svc.cluster.local:3000/{{ gitea_admin_username }}/{{ gitea_gitops_repo }}
      targetRevision: HEAD
      ref: values
  destination:
    server: https://kubernetes.default.svc
    namespace: '{{ firefly_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
