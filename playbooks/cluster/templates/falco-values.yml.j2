# ==============================================================================
# Falco Helm Values
# ==============================================================================
# Configures the falcosecurity/falco Helm chart for homelab deployment.
#
# Driver: modern_ebpf — uses CO-RE (Compile Once, Run Everywhere) so no kernel
# module or separate eBPF probe download is required. Requires kernel 5.8+ with
# BTF support. Requires chart >= 8.x for kernel 6.17+ compatibility.
#
# Falcosidekick is deployed as a subchart and forwards alerts to Alertmanager.
# The chart automatically configures Falco's http_output and json_output when
# falcosidekick.enabled is true.
#
# Custom rules (homelab_rules.yaml) extend the default ruleset with detections
# relevant to the homelab threat model:
#   - Kubeconfig file read from inside a container (credential theft)
#   - Unexpected process in a CNPG database pod (database compromise)
#   - Crypto mining heuristics (stratum protocol port 3333/14444)
#
# Default rules disabled via override (chronic false positives in this cluster):
#   - Run shell untrusted: CNPG postgres invokes 'sh -c manager wal-archive'
#     for every WAL segment archive; firefly's s6-overlay nginx health check
#     spawns 'sh ./data/check' on a timer. Both are operator-internal and
#     fire hundreds of times per hour.
#   - Linux Kernel Module Injection Detected: Longhorn's instance-manager
#     calls 'iscsiadm -m discovery' which loads kernel modules during volume
#     attach. Required for storage to work; not suppressible by namespace
#     scoping because the rule has no namespace exception hook upstream.
#   - Redirect STDOUT/STDIN to Network Connection in Container: Longhorn's
#     loopback gRPC self-talk and wait-for-it.sh startup gates trigger this.
#     Low-signal rule for a Kubernetes workload.
#
# Default rule kept with exception:
#   - Terminal shell in container: only fires on processes with an attached
#     TTY, so it's a clean kubectl-exec detection. open-webui's entrypoint
#     runs interactively (bash start.sh) and is the only known false positive.

driver:
  kind: modern_ebpf

falco:
  log_level: info

falcosidekick:
  enabled: true
  webui:
    enabled: true
    disableauth: true
  config:
    alertmanager:
      hostport: '{{ falco_alertmanager_hostport }}'
      endpoint: /api/v2/alerts
      minimumpriority: warning

customRules:
  homelab_rules.yaml: |-
    - rule: Read sensitive file untrusted
      condition: >
        open_read
        and sensitive_files
        and proc_name_exists
        {%- if falco_sensitive_file_container_only %}
        and container
        {%- endif %}
        and not proc.name in (user_mgmt_binaries, userexec_binaries, package_mgmt_binaries,
         cron_binaries, read_sensitive_file_binaries, shell_binaries, hids_binaries,
         vpn_binaries, mail_config_binaries, nomachine_binaries, sshkit_script_binaries,
         in.proftpd, mandb, salt-call, salt-minion, postgres_mgmt_binaries,
         google_oslogin_)
        and not cmp_cp_by_passwd
        and not ansible_running_python
        and not run_by_qualys
        and not run_by_chef
        and not run_by_google_accounts_daemon
        and not user_read_sensitive_file_conditions
        and not mandb_postinst
        and not perl_running_plesk
        and not perl_running_updmap
        and not veritas_driver_script
        and not perl_running_centrifydc
        and not runuser_reading_pam
        and not linux_bench_reading_etc_shadow
      override:
        condition: replace

    - rule: Run shell untrusted
      override:
        enabled: replace
      enabled: false

    - rule: Linux Kernel Module Injection Detected
      override:
        enabled: replace
      enabled: false

    - rule: Redirect STDOUT/STDIN to Network Connection in Container
      override:
        enabled: replace
      enabled: false

    - rule: Terminal shell in container
      override:
        condition: append
      condition: >
        and not (k8s.ns.name = "open-webui" and
                 proc.cmdline startswith "bash start.sh")

    - rule: Kubeconfig file read in container
      desc: >
        A process inside a container read a kubeconfig file. This may indicate
        an attempt to steal cluster credentials and pivot to the control plane.
      condition: >
        open_read and
        container and
        (fd.name glob '/root/.kube/*' or
         fd.name glob '/home/*/.kube/*' or
         fd.name = '/etc/kubernetes/admin.conf')
      output: >
        Kubeconfig file read inside container
        (user=%user.name cmd=%proc.cmdline file=%fd.name
        container=%container.name image=%container.image.repository
        ns=%k8s.ns.name pod=%k8s.pod.name)
      priority: WARNING
      tags: [homelab, credentials, kubernetes]

    - rule: Unexpected process in database pod
      desc: >
        A process other than the expected postgres executables was spawned inside
        a CNPG database pod, which may indicate a compromise or injection attack.
      condition: >
        spawned_process and
        container and
        k8s.ns.name = cnpg-system and
        not proc.name in (postgres, pg_ctl, pg_dump, pg_restore,
                          pg_basebackup, psql, sh, bash, manager,
                          bootstrap, initdb)
      output: >
        Unexpected process in database pod
        (user=%user.name cmd=%proc.cmdline pid=%proc.pid
        container=%container.name image=%container.image.repository
        pod=%k8s.pod.name)
      priority: ERROR
      tags: [homelab, database, anomaly]

    - rule: Crypto mining network activity
      desc: >
        A container attempted a network connection on a port commonly used by
        crypto mining pools. Ports 3333, 4444, 5555, 7777, and 14444 are
        standard Stratum protocol ports used by pools for Monero, Ethereum,
        and similar coins. Port 45700 is associated with XMRig and similar
        mining software. Loopback destinations are excluded to avoid false
        positives from legitimate health checks (e.g. Longhorn, Traefik).
      condition: >
        outbound and
        container and
        fd.rport in (3333, 4444, 5555, 7777, 14444, 45700) and
        not fd.rip in ("127.0.0.1", "::1")
      output: >
        Possible crypto mining outbound connection
        (user=%user.name cmd=%proc.cmdline connection=%fd.name
        container=%container.name image=%container.image.repository
        ns=%k8s.ns.name pod=%k8s.pod.name)
      priority: CRITICAL
      tags: [homelab, cryptomining, network]
