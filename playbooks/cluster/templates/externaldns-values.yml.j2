provider:
  name: rfc2136

extraArgs:
  - --rfc2136-host={{ bind9_service_ip }}
  - --rfc2136-port=53
  - --rfc2136-zone={{ dns_zone }}
  - --rfc2136-tsig-keyname=externaldns-key
  - --rfc2136-tsig-secret-alg=hmac-sha256
  - --rfc2136-tsig-secret={{ bind9_tsig_secret }}
  - --rfc2136-tsig-axfr

sources:
  - gateway-httproute

policy: upsert-only
