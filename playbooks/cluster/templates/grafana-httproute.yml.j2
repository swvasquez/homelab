{#
  Defines the HTTPRoute that exposes the Grafana UI over the LAN via the
  traefik-gateway. Routes HTTPS traffic matching the Grafana hostname to the
  kube-prometheus-stack-grafana Service on port 80. HTTP traffic is redirected
  to HTTPS by the Traefik entrypoint redirect configured in
  traefik-values.yml.j2 — no per-route HTTP redirect is needed.

  When with_forward_auth is true, the Authentik ForwardAuth middleware is applied
  to the route, requiring authentication before the request reaches the backend.
  The middleware must be deployed to the observability namespace before enabling this.

  Variables:
    grafana_hostname:     Fully qualified hostname for the Grafana UI
                          (e.g. grafana.homelab.internal).
    observability_namespace: Kubernetes namespace where the observability stack is deployed.
    with_forward_auth:    When true, applies the authentik-forward-auth Middleware
                          to the route (default: false).
#}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana
  namespace: '{{ observability_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ grafana_hostname }}'
  rules:
{% if with_forward_auth | default(false) %}
    - filters:
        - type: ExtensionRef
          extensionRef:
            group: traefik.io
            kind: Middleware
            name: authentik-forward-auth
      backendRefs:
        - name: kube-prometheus-stack-grafana
          port: 80
{% else %}
    - backendRefs:
        - name: kube-prometheus-stack-grafana
          port: 80
{% endif %}
