{#
  Defines the HTTPRoute that exposes the Authentik UI over the LAN via the traefik-gateway.
  Routes HTTPS traffic matching the Authentik hostname to the authentik-server Service on
  port 80. HTTP traffic is redirected to HTTPS by the Traefik entrypoint redirect configured
  in traefik-values.yml.j2 — no per-route HTTP redirect is needed.

  Authentik is intentionally not protected by the ForwardAuth middleware since it is the
  identity provider itself.

  Variables:
    authentik_hostname:  FQDN for the Authentik UI (e.g. authentik.homelab.internal).
    authentik_namespace: Kubernetes namespace where Authentik is deployed.
#}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: authentik
  namespace: '{{ authentik_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ authentik_hostname }}'
  rules:
    - backendRefs:
        - name: authentik-server
          port: 80
