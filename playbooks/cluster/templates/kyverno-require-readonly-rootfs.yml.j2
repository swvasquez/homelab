{#
  Kyverno ClusterPolicy: require-readonly-rootfs

  Audits any Pod whose containers do not set
  'securityContext.readOnlyRootFilesystem: true'. PSA 'restricted' does not
  require this field — it is an additional defense-in-depth layer that
  prevents an attacker who has gained code execution inside a container
  from writing tooling, persistence hooks, or modified binaries to the
  container's writable layer. Workloads that genuinely need scratch space
  (caches, sockets) should mount an emptyDir or PVC at the writable path
  instead of relying on the container's overlay.

  This policy runs in Enforce mode. The firefly-iii namespace is
  additionally excluded because the fireflyiii/core image is built on
  serversideup/php whose entrypoint chain renders nginx and php-fpm
  config straight into /etc at startup — making readOnlyRootFilesystem
  incompatible without a non-trivial init-container retrofit. See the
  exception comment in playbooks/services/templates/firefly-values.yml.j2.

  Variables:
    kyverno_app_namespace_selector: Label selector that matches the
                                    application namespaces this policy
                                    applies to. Defined in
                                    playbooks/cluster/security.yml.
#}
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: require-readonly-rootfs
  annotations:
    policies.kyverno.io/title: Require Read-Only Root Filesystem
    policies.kyverno.io/category: Pod Security
    policies.kyverno.io/severity: medium
    policies.kyverno.io/subject: Pod
    policies.kyverno.io/description: >-
      Containers should run with a read-only root filesystem to limit what
      an attacker can persist after gaining code execution inside the pod.
spec:
  validationFailureAction: Enforce
  background: true
  rules:
    - name: validate-readonly-rootfs
      match:
        any:
          - resources:
              kinds:
                - Pod
              namespaceSelector:
                matchExpressions:
                  - key: kubernetes.io/metadata.name
                    operator: NotIn
                    values:
                      - kube-system
                      - longhorn-system
                      - cnpg-system
                      - cert-manager
                      - vllm
                      - observability
                      - falco
                      - firefly-iii
      validate:
        message: >-
          Every container must set
          'securityContext.readOnlyRootFilesystem: true'. Mount an
          emptyDir or PVC at any path the workload needs to write to.
        pattern:
          spec:
            containers:
              - securityContext:
                  readOnlyRootFilesystem: true
            =(initContainers):
              - securityContext:
                  readOnlyRootFilesystem: true
            =(ephemeralContainers):
              - securityContext:
                  readOnlyRootFilesystem: true
