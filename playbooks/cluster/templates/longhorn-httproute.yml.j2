{#
  Defines the HTTPRoute that exposes the Longhorn UI over the LAN via the traefik-gateway.
  Routes HTTPS traffic matching the Longhorn hostname to the longhorn-frontend Service on
  port 80. HTTP traffic is redirected to HTTPS by the Traefik entrypoint redirect configured
  in traefik-values.yml.j2 — no per-route HTTP redirect is needed.

  Variables:
    longhorn_hostname:  Fully qualified hostname for the Longhorn UI (e.g. longhorn.homelab.internal).
    longhorn_namespace: Kubernetes namespace where Longhorn is deployed.
#}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: longhorn-ui
  namespace: '{{ longhorn_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ longhorn_hostname }}'
  rules:
    - backendRefs:
        - name: longhorn-frontend
          port: 80
