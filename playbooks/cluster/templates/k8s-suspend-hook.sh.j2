#!/bin/bash
# ==============================================================================
# k8s-suspend.sh
# ==============================================================================
# Local-only node lifecycle script for system suspend and resume. Called by
# k8s-suspend.service via ExecStart (pre-suspend) and ExecStop (post-resume).
# Works for both S3 and S0ix (modern standby).
#
# NOTE: This path is NOT used in the production nightly cycle. shutdown_mode
# is set to `shutdown` in group_vars/homelab.yml because s2idle is fragile
# on this hardware — the Ryzen workstation BIOS exposes only s2idle (no S3),
# and s0ix deep sleep is never actually entered (S0ix Entry Time: 0 in
# amd_pmc stats). Shallow s2idle bounces out within 20–30 seconds from any
# residual interrupt, so nodes cold-boot via WoL instead. This script stays
# here for manual `systemctl suspend` testing. See boot-lifecycle.md
# failure mode #4 for the full diagnosis.
#
# Design: treat suspend as an unclean event (like a brief power loss) rather
# than orchestrating a graceful cluster-wide drain. Longhorn is designed to
# recover from node failure, so we just need to stop services locally in an
# order that guarantees iSCSI sessions are cleanly torn down before suspend.
# No kubectl, no drain, no taint, no cross-node coordination.
#
# Why the teardown order matters:
#   - If /dev/sd* devices remain while the system suspends, the kernel spews
#     journal/filesystem I/O errors when the iSCSI TCP connections die during
#     suspend. So we MUST ensure every /dev/sd* is gone before stopping iscsid.
#   - Longhorn engine pods run on-node and serve iSCSI targets on 127.0.0.1.
#     If a Longhorn engine exits before a workload pod finishes flushing its
#     ext4 journal, the workload writes into a dead iSCSI target — producing
#     the "potential data loss" / "Aborting journal" / "EXT4-fs: shut down"
#     errors seen in dmesg after suspend. We therefore stop containers in two
#     phases so the iSCSI target outlives every writer of the filesystem it
#     serves.
#   - Leaving docker, cri-docker, and iscsid running across suspend was
#     tested and abandoned: s2idle (the kernel sleep state used on this
#     hardware) wakes on essentially any activity, and the background chatter
#     from running services caused the machine to bounce out of sleep within
#     a few seconds. Stopping them lets s2idle actually hold.
#
# Pre-suspend phases:
#   1. Stop kubelet so no new pods are scheduled mid-teardown.
#   2. Phase 1: gracefully stop WORKLOAD containers only (everything not in
#      longhorn-system or kube-system). Their ext4 writes complete against a
#      live iSCSI target.
#   3. Wait for pod-level CSI bind mounts to deactivate (systemd transient
#      scope units from PR #49640 clean these up when containers exit).
#   4. sync — flush dirty page cache to the still-live iSCSI target.
#   5. Verify iSCSI sessions are still alive; if they are, force-unmount any
#      remaining CSI global mounts. If they are already dead, skip umount to
#      avoid D-state hangs on unreachable block devices.
#   6. iscsiadm --logout closes the now-quiescent sessions cleanly.
#   7. Wait for /dev/sd* iSCSI-backed devices to disappear.
#   8. Phase 2: stop SYSTEM containers (longhorn-system, kube-system). Their
#      iSCSI targets have already been logged out, so nothing can still be
#      writing through them.
#   9. Stop cri-docker and docker services.
#  10. Stop iscsid so it cannot reconnect during suspend.
#
# On post-resume:
#   1. Start iscsid so Longhorn can reconnect iSCSI targets on demand.
#   2. Start docker and cri-docker.
#   3. Start kubelet; Longhorn and workload pods reconcile on their own.
# ==============================================================================

set -o pipefail

LOG_TAG='k8s-suspend-hook'
CONTAINER_GRACE_WORKLOAD=30
CONTAINER_GRACE_SYSTEM=15
DEVICE_DETACH_TIMEOUT=60
POD_MOUNT_CLEAR_TIMEOUT=20
ISCSI_DISCONNECT_TIMEOUT={{ k8s_iscsi_disconnect_timeout }}
SYSTEM_NAMESPACES=(longhorn-system kube-system)

HOOK_START_TS=$(date +%s)

log() {
    local elapsed=$(( $(date +%s) - HOOK_START_TS ))
    printf '[+%04ds] %s\n' "$elapsed" "$1" | systemd-cat -t "$LOG_TAG" -p info
}

log_err() {
    local elapsed=$(( $(date +%s) - HOOK_START_TS ))
    printf '[+%04ds] %s\n' "$elapsed" "$1" | systemd-cat -t "$LOG_TAG" -p err
}

# Classify running containers by Kubernetes pod namespace.
# Populates globals WORKLOAD_IDS and SYSTEM_IDS (newline-separated).
# Unlabeled containers (non-k8s docker containers) are treated as workload
# on the assumption that they do not own iSCSI targets.
classify_containers() {
    WORKLOAD_IDS=''
    SYSTEM_IDS=''
    local raw
    raw=$(timeout 10 docker ps --format {% raw %}'{{.ID}} {{.Label "io.kubernetes.pod.namespace"}}'{% endraw %} 2>/dev/null)
    if [[ -z "$raw" ]]; then
        log 'No running containers'
        return 0
    fi
    # Build a regex like "^(longhorn-system|kube-system)$" for exact ns match.
    local ns_pattern
    ns_pattern=$(IFS='|'; echo "^(${SYSTEM_NAMESPACES[*]})$")
    WORKLOAD_IDS=$(awk -v pat="$ns_pattern" '$2 !~ pat {print $1}' <<< "$raw")
    SYSTEM_IDS=$(awk -v pat="$ns_pattern" '$2 ~ pat {print $1}' <<< "$raw")
    local w=0 s=0
    [[ -n "$WORKLOAD_IDS" ]] && w=$(wc -l <<< "$WORKLOAD_IDS")
    [[ -n "$SYSTEM_IDS" ]] && s=$(wc -l <<< "$SYSTEM_IDS")
    log "Classified containers: ${w} workload, ${s} system (${SYSTEM_NAMESPACES[*]})"
}

stop_container_set() {
    # Arguments: <label> <grace-seconds> <ids-newline-separated>
    local label=$1
    local grace=$2
    local ids=$3
    if [[ -z "$ids" ]]; then
        log "${label}: nothing to stop"
        return 0
    fi
    local count
    count=$(wc -l <<< "$ids")
    log "${label}: stopping ${count} container(s) with ${grace}s grace"
    # shellcheck disable=SC2086
    timeout $(( grace + 20 )) docker stop -t "$grace" $(tr '\n' ' ' <<< "$ids") &>/dev/null || true
    log "${label}: stop issued"
}

wait_for_pod_csi_bind_mounts_gone() {
    # Pod-level CSI bind mounts (/var/lib/kubelet/pods/*/volumes/kubernetes.io~csi/*)
    # are tracked by kubelet as systemd transient scope units (PR #49640). They
    # deactivate when the owning pod's containers exit. Wait for this so umount
    # of the globalmount is not blocked by still-nested bind mounts.
    local deadline=$(( $(date +%s) + POD_MOUNT_CLEAR_TIMEOUT ))
    log "Waiting for pod-level CSI bind mounts to deactivate (timeout: ${POD_MOUNT_CLEAR_TIMEOUT}s)"
    while awk '$2 ~ "/var/lib/kubelet/pods/.*kubernetes.io~csi" {f=1} END {exit !f}' /proc/mounts; do
        if (( $(date +%s) >= deadline )); then
            log_err 'Pod-level CSI bind mounts still present after timeout — proceeding anyway'
            return 0
        fi
        sleep 1
    done
    log 'Pod-level CSI bind mounts cleared'
}

unmount_csi_volumes() {
    log 'Force-unmounting any lingering kubelet CSI volume mounts'
    local mp
    # Deepest paths first so bind mounts unmount before their sources.
    # Scoped to /var/lib/kubelet to avoid ever touching the root filesystem.
    while read -r mp; do
        [[ -z "$mp" ]] && continue
        log "Unmounting $mp"
        if ! timeout 10 umount "$mp" &>/dev/null; then
            # Kill any processes still holding the mount open, then retry.
            # A clean umount (not lazy) is essential — it flushes the ext4
            # journal before returning. umount -l detaches the mount point
            # but leaves the filesystem accessible via open FDs; when iSCSI
            # logs out those FDs get I/O errors and ext4 aborts its journal.
            log "Unmount of $mp busy — killing holders and retrying"
            timeout 5 fuser -km "$mp" &>/dev/null || true
            sleep 1
            timeout 10 umount "$mp" &>/dev/null \
                || timeout 10 umount -l "$mp" &>/dev/null \
                || log_err "Failed to unmount $mp"
        fi
    done < <(awk '$2 ~ "kubernetes.io~csi|/plugins/kubernetes.io/csi" {print $2}' /proc/mounts | sort -r)
}

iscsi_sessions_active() {
    timeout 5 iscsiadm -m session &>/dev/null
}

iscsi_target_reachable() {
    # Same probe as iscsi_sessions_active; named separately so intent is clear
    # at the call site. Purpose: gate the umount step. An ext4 umount must
    # flush the journal to the block device; if the iSCSI session is already
    # dead, the umount enters uninterruptible D-state and cannot be killed
    # even by SIGKILL (this is what produces the ~99s SIGKILL of the outer
    # service). If no session is alive, skipping umount is the only safe
    # action — the data was already unreachable before we got here.
    iscsi_sessions_active
}

iscsi_devices_present() {
    # Check for iSCSI-backed block devices by looking at the iscsi_session sysfs tree.
    # Avoids falsely matching local SATA/SAS disks which are also /dev/sd*.
    ls /sys/class/iscsi_session/*/device/target*/*/block/sd* &>/dev/null 2>&1
}

detach_iscsi_devices() {
    # One pass of: unmount lingering CSI mounts → logout iSCSI sessions.
    # Called in a retry loop so it is safe to call multiple times.
    unmount_csi_volumes
    log 'Logging out iSCSI sessions'
    timeout 30 iscsiadm -m node --logout &>/dev/null || true
}

wait_for_iscsi_detach() {
    # Retry detach_iscsi_devices until all iSCSI-backed block devices are gone or
    # the hard deadline is reached. Retrying handles the case where a mount was
    # still busy on the first pass (preventing logout), then becomes free after a
    # moment of settling.
    local deadline=$(( $(date +%s) + DEVICE_DETACH_TIMEOUT ))
    local pass=1
    log "Waiting for iSCSI devices to detach (timeout: ${DEVICE_DETACH_TIMEOUT}s)"
    while iscsi_devices_present || iscsi_sessions_active; do
        if (( $(date +%s) >= deadline )); then
            log_err 'Timed out waiting for iSCSI devices to detach — suspend may hit I/O errors'
            return 0
        fi
        log "Pass ${pass}: iSCSI devices or sessions still active — retrying cleanup"
        detach_iscsi_devices
        pass=$(( pass + 1 ))
        sleep 3
    done
    log 'All iSCSI devices detached and sessions cleared'
}

start_service_with_retry() {
    # Bring a unit to active state; if it does not reach active, reset and restart
    # once. Post-resume services chain dependencies (iscsid → docker → cri-docker
    # → kubelet), so silent failures upstream cascade into unhealthy kubelet.
    local unit=$1
    local start_timeout=$2
    log "Starting ${unit}"
    timeout "$start_timeout" systemctl start "$unit" &>/dev/null || true
    if timeout 5 systemctl is-active --quiet "$unit"; then
        return 0
    fi
    log_err "${unit} failed to become active — resetting and retrying once"
    timeout 10 systemctl reset-failed "$unit" &>/dev/null || true
    timeout "$start_timeout" systemctl restart "$unit" &>/dev/null || true
    if timeout 5 systemctl is-active --quiet "$unit"; then
        log "${unit} recovered on retry"
        return 0
    fi
    log_err "${unit} still not active after retry — continuing anyway"
    return 1
}

case "$1" in
    pre)
        log 'Pre-suspend: stopping kubelet'
        timeout 60 systemctl stop kubelet &>/dev/null || true
        if systemctl is-active --quiet kubelet 2>/dev/null; then
            log_err 'Kubelet still running after stop — sending SIGKILL'
            systemctl kill --signal=SIGKILL kubelet &>/dev/null || true
            sleep 2
        fi

        # ----------------------------------------------------------------------
        # Phase 1: stop workload containers while Longhorn and kube-system pods
        # remain alive. Workload pods (e.g. postgres, valkey) need a reachable
        # iSCSI target on 127.0.0.1:3260 to flush their ext4 journals cleanly.
        # If Longhorn's engine exits before the workload pod finishes its
        # SIGTERM handler, the journal is left inconsistent — the exact failure
        # mode producing "Aborting journal" / "potential data loss" messages
        # in dmesg after suspend.
        # ----------------------------------------------------------------------
        classify_containers
        stop_container_set 'Phase 1 (workload containers)' \
            "$CONTAINER_GRACE_WORKLOAD" "$WORKLOAD_IDS"

        wait_for_pod_csi_bind_mounts_gone

        # Flush all dirty page cache while iSCSI targets are still live. After
        # phase 1 no workload can issue new writes, so this sync finalizes
        # everything that matters for data integrity.
        log 'Syncing pending writes (iSCSI targets still live)'
        timeout 30 sync || log_err 'sync timed out — proceeding anyway'

        # LOAD-BEARING GUARD — DO NOT REMOVE the iscsi_target_reachable check.
        # An ext4 umount on a dead iSCSI target blocks in uninterruptible
        # D-state and cannot be killed even by SIGKILL. This historically
        # caused the outer service to be SIGKILL'd at the sleep.target job
        # timeout (~99s), which tore down iSCSI/ext4 abruptly and produced
        # the "Aborting journal" / "shut down requested (2)" dmesg cascade.
        # If sessions are already dead, skipping umount is the only safe
        # action — the data was already unreachable before we got here.
        if iscsi_target_reachable; then
            unmount_csi_volumes
        else
            log_err 'iSCSI sessions already dead — skipping umount to avoid D-state hang'
        fi

        log 'Logging out iSCSI sessions'
        timeout 30 iscsiadm -m node --logout &>/dev/null || true
        wait_for_iscsi_detach

        # ----------------------------------------------------------------------
        # Phase 2: stop Longhorn and kube-system containers. iSCSI targets have
        # already been logged out and block devices are gone, so nothing can
        # still be writing through them. A shorter grace period is enough —
        # Longhorn has no ext4 journals of its own to flush at this point.
        #
        # LOAD-BEARING — DO NOT REMOVE OR "SIMPLIFY" Phase 2 + the service
        # stops below. This was tested in commit history: leaving docker,
        # cri-docker, iscsid, and system containers running across suspend
        # causes s2idle (the kernel sleep state on this hardware) to bounce
        # out of sleep within ~3 seconds from residual background chatter.
        # Symptom: `PM: suspend entry (s2idle)` followed by `PM: suspend
        # exit` within seconds, with no user wake event. The only known cure
        # is this aggressive teardown.
        # ----------------------------------------------------------------------
        stop_container_set 'Phase 2 (system containers)' \
            "$CONTAINER_GRACE_SYSTEM" "$SYSTEM_IDS"

        log 'Stopping cri-docker and docker services'
        timeout 30 systemctl stop cri-docker.service cri-docker.socket &>/dev/null || true
        timeout 60 systemctl stop docker.service docker.socket &>/dev/null || true

        log 'Stopping iscsid'
        timeout 15 systemctl stop iscsid.socket iscsid.service &>/dev/null || true

        log 'Pre-suspend complete'
        ;;
    post)
        start_service_with_retry iscsid.socket 30
        start_service_with_retry iscsid.service 30

        # Clear any stale iSCSI session state left over from the pre-suspend path.
        # If logout timed out before suspend, the kernel may still be holding
        # session metadata that will collide with Longhorn's fresh reconnect.
        log 'Clearing any stale iSCSI sessions'
        timeout 15 iscsiadm -m node --logoutall=all &>/dev/null || true

        start_service_with_retry docker.service 60
        start_service_with_retry cri-docker.socket 30
        start_service_with_retry cri-docker.service 30
        start_service_with_retry kubelet.service 30

        log 'Post-resume service state:'
        for unit in iscsid.service docker.service cri-docker.service kubelet.service; do
            state=$(timeout 5 systemctl is-active "$unit" 2>/dev/null || echo unknown)
            log "  ${unit}: ${state}"
        done

        log 'Post-resume complete'
        ;;
    *)
        log_err "Unknown action: $1 (expected 'pre' or 'post')"
        exit 1
        ;;
esac
