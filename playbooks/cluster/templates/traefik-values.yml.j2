{#
  Helm values for Traefik ingress controller.

  Configures Traefik to act as a Gateway API controller using the kubernetesGateway
  provider. The kubernetesCRD provider is also enabled with cross-namespace access so
  that Middleware resources defined in one namespace can be referenced by routes in
  other namespaces. The kubernetesIngress provider is disabled as Gateway API HTTPRoutes
  are used exclusively. A LoadBalancer service is created so Traefik receives a stable
  LAN IP from the Cilium IP pool. HTTP traffic is redirected to HTTPS by the web
  entrypoint redirect. The built-in dashboard ingressRoute is disabled in favor of
  the manually created HTTPRoute. Access logs are enabled for observability.

  Variables:
    traefik_http_port:  External LoadBalancer port for HTTP (the web entrypoint).
                        Derived from ufw_allowed_ports.traefik_http.port in group_vars.
    traefik_https_port: External LoadBalancer port for HTTPS (the websecure entrypoint).
                        Derived from ufw_allowed_ports.traefik_https.port in group_vars.
    IMPORTANT: every time a new service is deployed with an ExtensionRef middleware
    filter (e.g. ForwardAuth) in its HTTPRoute, its namespace must be added to the
    kubernetesCRD namespaces allowlist below and cluster/network.yml must be re-run,
    or Traefik will silently drop the filter and return 500.
#}
providers:
  kubernetesGateway:
    enabled: true
  kubernetesCRD:
    enabled: true
    allowCrossNamespace: true
    namespaces:
      - traefik
      - kube-system
      - longhorn-system
      - observability
      - gitea
      - argocd
      - immich
      - syncthing
      - open-webui
      - firefly-iii
      - vaultwarden
      - jellyfin
  kubernetesIngress:
    enabled: false

service:
  type: LoadBalancer

ports:
  traefik:
    expose:
      default: true
  web:
    exposedPort: {{ traefik_http_port }}
    redirections:
      entryPoint:
        to: websecure
        scheme: https
  websecure:
    exposedPort: {{ traefik_https_port }}

gateway:
  enabled: false

additionalArguments:
  - '--api.insecure=true'

ingressRoute:
  dashboard:
    enabled: false

accessLog:
  enabled: true
