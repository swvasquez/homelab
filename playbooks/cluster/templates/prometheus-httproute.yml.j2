{#
  Defines the HTTPRoute that exposes the Prometheus UI over the LAN via the
  traefik-gateway. Routes HTTPS traffic matching the Prometheus hostname to the
  kube-prometheus-stack-prometheus Service on port 9090. HTTP traffic is
  redirected to HTTPS by the Traefik entrypoint redirect configured in
  traefik-values.yml.j2 — no per-route HTTP redirect is needed.

  When with_forward_auth is true, the Authentik ForwardAuth middleware is applied
  to the route, requiring authentication before the request reaches the backend.
  The middleware must be deployed to the observability namespace before enabling this.

  Variables:
    prometheus_hostname:  Fully qualified hostname for the Prometheus UI
                          (e.g. prometheus.homelab.internal).
    observability_namespace: Kubernetes namespace where the observability stack is deployed.
    with_forward_auth:    When true, applies the authentik-forward-auth Middleware
                          to the route (default: false).
#}
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: prometheus
  namespace: '{{ observability_namespace }}'
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ prometheus_hostname }}'
  rules:
{% if with_forward_auth | default(false) %}
    - filters:
        - type: ExtensionRef
          extensionRef:
            group: traefik.io
            kind: Middleware
            name: authentik-forward-auth
      backendRefs:
        - name: kube-prometheus-stack-prometheus
          port: 9090
{% else %}
    - backendRefs:
        - name: kube-prometheus-stack-prometheus
          port: 9090
{% endif %}
