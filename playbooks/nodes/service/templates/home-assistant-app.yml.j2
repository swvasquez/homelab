{#
  ArgoCD Application manifest for the Home Assistant deployment. Tracks the
  native Kubernetes manifests stored in the Gitea gitops repository. Any push
  to the gitops repository triggers an immediate sync via the Gitea webhook
  registered by argocd.yml.

  Variables:
    argocd_namespace:           Kubernetes namespace where ArgoCD is deployed.
    home_assistant_namespace:   Kubernetes namespace where Home Assistant will
                                be deployed.
    home_assistant_gitops_path: Path within the gitops repository to the Home
                                Assistant manifests (e.g. apps/home-assistant).
    gitea_namespace:            Kubernetes namespace where Gitea is deployed.
    gitea_admin_username:       Gitea admin username that owns the gitops
                                repository.
    gitea_gitops_repo:          Name of the Gitea gitops repository.
#}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: home-assistant
  namespace: '{{ argocd_namespace }}'
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: 'http://gitea-http.{{ gitea_namespace }}.svc.cluster.local:3000/{{ gitea_admin_username }}/{{ gitea_gitops_repo }}'
    path: '{{ home_assistant_gitops_path }}'
    targetRevision: main
  destination:
    server: https://kubernetes.default.svc
    namespace: '{{ home_assistant_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
