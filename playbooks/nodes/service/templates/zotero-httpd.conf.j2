{#
  Apache httpd configuration for the Zotero WebDAV endpoint. Inlined into
  the zotero-webdav-config ConfigMap (templates/zotero-manifests.yml.j2)
  via Jinja `lookup('template', ...)` at render time, then mounted into
  the Apache container at /usr/local/apache2/conf/httpd.conf.

  The pod runs as a non-root user under the restricted Pod Security
  Admission profile, so Apache listens on an unprivileged port and never
  tries to setuid. Logs are piped to the container's stdout/stderr so
  `kubectl logs` surfaces them directly. The container's root filesystem
  is read-only; the PID file and the mod_dav lock DB therefore live on
  emptyDir mounts under /tmp and /var/lib/dav/lock.

  Variables:
    zotero_listen_port:     Unprivileged port Apache binds to inside the
                            pod (e.g. 8080).
    zotero_hostname:        FQDN under which the WebDAV endpoint is
                            reachable; set as Apache's ServerName so
                            self-referential headers generated by mod_dav
                            contain the correct host value.
    zotero_max_upload_size: Maximum request body size in bytes accepted by
                            Apache (LimitRequestBody). Caps the size of any
                            single attachment uploaded by a Zotero client.
#}
# Minimal Apache configuration for the Zotero WebDAV endpoint.

ServerRoot "/usr/local/apache2"
Listen {{ zotero_listen_port }}
ServerName {{ zotero_hostname }}

# Core MPM and platform modules.
LoadModule mpm_event_module modules/mod_mpm_event.so
LoadModule unixd_module modules/mod_unixd.so

# Authentication and authorization for Basic Auth via htpasswd.
LoadModule authn_core_module modules/mod_authn_core.so
LoadModule authn_file_module modules/mod_authn_file.so
LoadModule authz_core_module modules/mod_authz_core.so
LoadModule authz_user_module modules/mod_authz_user.so
LoadModule auth_basic_module modules/mod_auth_basic.so

# Logging, MIME, URL handling.
LoadModule log_config_module modules/mod_log_config.so
LoadModule mime_module modules/mod_mime.so
LoadModule dir_module modules/mod_dir.so
LoadModule alias_module modules/mod_alias.so
LoadModule headers_module modules/mod_headers.so
LoadModule setenvif_module modules/mod_setenvif.so

# WebDAV.
LoadModule dav_module modules/mod_dav.so
LoadModule dav_fs_module modules/mod_dav_fs.so

# Logs to the container runtime so 'kubectl logs' captures them.
ErrorLog "/proc/self/fd/2"
TransferLog "/proc/self/fd/1"
LogLevel warn

# PID and lock DB live on writable emptyDir mounts because the container
# filesystem is read-only under the restricted PSA profile.
PidFile "/tmp/httpd.pid"
DavLockDB "/var/lib/dav/lock/DavLock"

TypesConfig conf/mime.types

# Cap upload size. Zotero attachments are usually a few MiB each; any PUT
# larger than this is rejected with 413.
LimitRequestBody {{ zotero_max_upload_size }}

# WebDAV data lives in an NFS-backed PVC mounted into the container.
DocumentRoot "/var/lib/dav/data"

<Directory />
    AllowOverride None
    Require all denied
</Directory>

<Directory "/var/lib/dav/data">
    Options Indexes
    AllowOverride None
    Dav On
    AuthType Basic
    AuthName "Zotero WebDAV"
    AuthUserFile "/etc/apache2/htpasswd"
    Require valid-user
</Directory>
