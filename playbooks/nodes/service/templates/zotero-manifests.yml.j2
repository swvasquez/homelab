{#
  Native Kubernetes manifests for the Zotero WebDAV server, deployed via
  ArgoCD. Contains every resource ArgoCD manages for this service:

    - ExternalSecret           Pulls the htpasswd line from OpenBao and
                               materializes it as Secret
                               zotero-webdav-credentials.
    - ConfigMap                Apache httpd.conf used by the Deployment.
                               The actual httpd.conf body lives in a
                               separate template
                               (zotero-httpd.conf.j2) and is inlined
                               into this ConfigMap at render time via
                               Jinja `lookup('template', ...)`.
    - Service                  ClusterIP exposing Apache on port 80.
    - HTTPRoute                Attaches the Service to the traefik-gateway
                               at zotero_hostname. ForwardAuth is
                               intentionally NOT set: Zotero clients only
                               speak HTTP Basic Auth and Apache enforces
                               that itself via the htpasswd file.
    - Deployment               httpd container with mod_dav / mod_dav_fs.

  Apache is configured for WebDAV via mod_dav and mod_dav_fs. The Zotero
  clients (desktop and iOS) talk to this endpoint over HTTPS via Traefik,
  which terminates TLS using the homelab wildcard certificate and forwards
  plain HTTP to the Deployment. Apache itself listens on 8080 because the
  pod runs as a non-root user under the cluster's Pod Security Admission
  profile and cannot bind to ports below 1024.

  Storage:
    - zotero-webdav-data (NFS, RWX): WebDAV file tree, mounted at
      /var/lib/dav/data. Pre-created by zotero.yml before ArgoCD sync.
    - emptyDir mounts for /tmp, Apache logs and the DAV lock database — the
      restricted PSA profile requires readOnlyRootFilesystem and all writes
      must go to mounted volumes.

  Reloader:
    The Deployment is annotated with reloader.stakater.com/auto: 'true' so
    any change to zotero-webdav-credentials (the materialized Secret backing
    the htpasswd file) rolls the pod automatically.

  Variables:
    zotero_namespace:           Kubernetes namespace where the WebDAV server
                                is deployed.
    zotero_image:               Docker image for the Apache httpd server.
    zotero_image_tag:           Docker image tag for the Apache httpd server.
    zotero_listen_port:         Unprivileged port Apache listens on inside
                                the pod (default 8080).
    zotero_hostname:            Fully qualified DNS name under which the
                                WebDAV endpoint is reachable. Set as Apache's
                                ServerName so self-referential headers
                                generated by mod_dav contain the correct
                                host value, and as the HTTPRoute hostname.
    zotero_max_upload_size:     Maximum request body size in bytes accepted
                                by Apache. Caps the size of any single
                                attachment uploaded by a Zotero client.
    zotero_request_timeout:     Gateway API HTTPRoute request timeout. Must
                                be long enough to upload the largest
                                attachment over the LAN.
    zotero_htpasswd_kv_path:    OpenBao KV path (v2) holding the htpasswd
                                line for the WebDAV account. The
                                ExternalSecret reads its 'htpasswd' property
                                and materializes the Secret consumed by the
                                Deployment.
    nfs_group_gid:              GID of the NFS users group. Used as both
                                runAsGroup and fsGroup so the Apache process
                                can write to the NFS-backed WebDAV data
                                directory.
    nonroot_uid:                Non-root UID the pod runs as.
#}
---
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: zotero-webdav-credentials
  namespace: '{{ zotero_namespace }}'
spec:
  refreshInterval: 15m
  secretStoreRef:
    kind: ClusterSecretStore
    name: openbao
  target:
    name: zotero-webdav-credentials
  data:
    - secretKey: htpasswd
      remoteRef:
        key: '{{ zotero_htpasswd_kv_path | regex_replace("^secret/", "") }}'
        property: htpasswd
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: zotero-webdav-config
  namespace: '{{ zotero_namespace }}'
  labels:
    app.kubernetes.io/name: zotero-webdav
data:
  httpd.conf: |
{{ lookup('template', 'zotero-httpd.conf.j2') | indent(4, first=true) }}
---
apiVersion: v1
kind: Service
metadata:
  name: zotero-webdav
  namespace: '{{ zotero_namespace }}'
  labels:
    app.kubernetes.io/name: zotero-webdav
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: zotero-webdav
  ports:
    - name: http
      port: 80
      targetPort: {{ zotero_listen_port }}
      protocol: TCP
      appProtocol: http
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: zotero
  namespace: '{{ zotero_namespace }}'
  labels:
    app.kubernetes.io/name: zotero-webdav
spec:
  parentRefs:
    - name: traefik-gateway
      namespace: kube-system
      sectionName: https
  hostnames:
    - '{{ zotero_hostname }}'
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      timeouts:
        request: '{{ zotero_request_timeout }}'
      backendRefs:
        - name: zotero-webdav
          namespace: '{{ zotero_namespace }}'
          port: 80
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: zotero-webdav
  namespace: '{{ zotero_namespace }}'
  labels:
    app.kubernetes.io/name: zotero-webdav
  annotations:
    reloader.stakater.com/auto: 'true'
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app.kubernetes.io/name: zotero-webdav
  template:
    metadata:
      labels:
        app.kubernetes.io/name: zotero-webdav
    spec:
      securityContext:
        runAsUser: {{ nonroot_uid }}
        # Primary GID is the shared NFS users group because the WebDAV data
        # directory is on an NFSv4 share whose server does not honor
        # supplemental groups for permission checks — only the process's
        # primary gid matches the export's group ownership.
        runAsGroup: {{ nfs_group_gid }}
        runAsNonRoot: true
        fsGroup: {{ nfs_group_gid }}
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: httpd
          image: '{{ zotero_image }}:{{ zotero_image_tag }}'
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          ports:
            - name: http
              containerPort: {{ zotero_listen_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /usr/local/apache2/conf/httpd.conf
              subPath: httpd.conf
              readOnly: true
            - name: htpasswd
              mountPath: /etc/apache2/htpasswd
              subPath: htpasswd
              readOnly: true
            - name: data
              mountPath: /var/lib/dav/data
            - name: lock
              mountPath: /var/lib/dav/lock
            - name: logs
              mountPath: /usr/local/apache2/logs
            - name: tmp
              mountPath: /tmp
          readinessProbe:
            tcpSocket:
              port: {{ zotero_listen_port }}
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            tcpSocket:
              port: {{ zotero_listen_port }}
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
      volumes:
        - name: config
          configMap:
            name: zotero-webdav-config
            items:
              - key: httpd.conf
                path: httpd.conf
        - name: htpasswd
          secret:
            secretName: zotero-webdav-credentials
            items:
              - key: htpasswd
                path: htpasswd
        - name: data
          persistentVolumeClaim:
            claimName: zotero-webdav-data
        - name: lock
          emptyDir: {}
        - name: logs
          emptyDir: {}
        - name: tmp
          emptyDir: {}
