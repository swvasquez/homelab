{#
  ArgoCD Application manifest for the Zotero WebDAV deployment. Tracks the
  native Kubernetes manifests stored under apps/zotero in the Gitea gitops
  repository. Any push to that path triggers an immediate sync via the Gitea
  webhook registered by argocd.yml.

  Variables:
    argocd_namespace:       Kubernetes namespace where ArgoCD is deployed.
    zotero_namespace:       Kubernetes namespace where the WebDAV server
                            will be deployed.
    zotero_gitops_path:     Path within the gitops repository to the Zotero
                            manifests (e.g. apps/zotero).
    gitea_namespace:        Kubernetes namespace where Gitea is deployed.
    gitea_admin_username:   Gitea admin username that owns the gitops
                            repository.
    gitea_gitops_repo:      Name of the Gitea gitops repository.
#}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: zotero
  namespace: '{{ argocd_namespace }}'
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: 'http://gitea-http.{{ gitea_namespace }}.svc.cluster.local:3000/{{ gitea_admin_username }}/{{ gitea_gitops_repo }}'
    path: '{{ zotero_gitops_path }}'
    targetRevision: main
  destination:
    server: https://kubernetes.default.svc
    namespace: '{{ zotero_namespace }}'
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
