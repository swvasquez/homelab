#!/bin/sh
# Init-premount watchdog that powers the host off if the LUKS root volume is
# not unlocked within {{ dropbear_unlock_timeout }} seconds. Installed by
# playbooks/nodes/infrastructure/dropbear-initramfs.yml. The script polls
# /proc/mounts for the real root filesystem at /root, which only appears
# once cryptroot has unlocked the LUKS volume and the local stage has
# mounted root. The watchdog is torn down by switch_root once the real
# init takes over, so it only ever fires during the initramfs window.
PREREQ=''
prereqs() { echo "$PREREQ"; }
case "$1" in
    prereqs) prereqs; exit 0 ;;
esac

TIMEOUT={{ dropbear_unlock_timeout }}

(
    elapsed=0
    while [ "$elapsed" -lt "$TIMEOUT" ]; do
        if grep -q ' /root ' /proc/mounts; then
            exit 0
        fi
        sleep 5
        elapsed=$((elapsed + 5))
    done
    echo "LUKS unlock timeout reached after ${TIMEOUT}s; powering off." > /dev/kmsg
    poweroff -f
) &
