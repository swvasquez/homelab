{#
  Generic ExternalSecret manifest for the External Secrets Operator. Defines
  a declarative pointer that ESO uses to fetch a secret from the configured
  ClusterSecretStore (default: openbao) and materialize it as a regular
  Kubernetes Secret in the target namespace. Each entry in es_data maps one
  field of the remote OpenBao KV secret to a key in the resulting K8s
  Secret.

  Variables:
    es_name:               Name of the ExternalSecret resource.
    es_namespace:          Namespace where the ExternalSecret (and the
                           materialized K8s Secret) live.
    es_target_secret_name: Name of the K8s Secret ESO will create from the
                           remote data.
    es_data:               List of mappings, each a dict with keys:
                             secret_key      — destination key on the K8s
                                               Secret.
                             remote_key      — KV path under the store's
                                               base path (e.g. for the
                                               'openbao' store rooted at
                                               'secret/', a remote_key of
                                               'authentik/bootstrap_password'
                                               resolves to
                                               'secret/data/authentik/bootstrap_password').
                             remote_property — JSON property within the KV
                                               value document to read.
    es_refresh_interval:   (Optional) ESO poll interval. Default 15m.
                           For urgent rotations, prefer
                           'kubectl annotate externalsecret <name> -n <ns>
                           force-sync=$(date +%s) --overwrite' which
                           bypasses this entirely and syncs in seconds.
    es_store_name:         (Optional) ClusterSecretStore name to read from.
                           Default 'openbao'.
    es_target_template:    (Optional) Dict of {output_key: template_string}
                           rendered into the materialized K8s Secret. The
                           template strings can reference any data[].secret_key
                           via Go-template '{{ .secret_key }}' syntax. Use
                           '{% raw %}{{ .name }}{% endraw %}' inside the
                           caller's vars block to emit a literal Go-template
                           reference past Jinja. When set, the K8s Secret
                           contains exactly the keys listed here (keys from
                           data[].secret_key are NOT also included unless
                           re-emitted in the template).
    es_target_labels:      (Optional) Dict of labels to apply to the
                           materialized K8s Secret. Most commonly used to
                           opt the Secret into the cnpg.io Secret-watch
                           predicate ('cnpg.io/reload: "true"'); without
                           that label, CloudNativePG's managed.roles
                           controller silently ignores Secret data
                           changes and never runs ALTER USER.
#}
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: '{{ es_name }}'
  namespace: '{{ es_namespace }}'
spec:
  refreshInterval: '{{ es_refresh_interval | default("15m") }}'
  secretStoreRef:
    kind: ClusterSecretStore
    name: '{{ es_store_name | default("openbao") }}'
  target:
    name: '{{ es_target_secret_name }}'
{% if es_target_template is defined or es_target_labels is defined %}
    template:
      engineVersion: v2
      type: Opaque
{% if es_target_labels is defined %}
      metadata:
        labels:
{% for label_key, label_value in es_target_labels.items() %}
          {{ label_key }}: '{{ label_value }}'
{% endfor %}
{% endif %}
{% if es_target_template is defined %}
      data:
{% for key, value in es_target_template.items() %}
        {{ key }}: '{{ value }}'
{% endfor %}
{% endif %}
{% endif %}
  data:
{% for d in es_data %}
    - secretKey: '{{ d.secret_key }}'
      remoteRef:
        key: '{{ d.remote_key }}'
        property: '{{ d.remote_property }}'
{% endfor %}
