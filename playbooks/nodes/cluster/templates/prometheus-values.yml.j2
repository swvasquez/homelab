{#
  Helm values for kube-prometheus-stack. Configures Prometheus, Grafana, and
  Alertmanager. Native Ingress is disabled for all three components — UIs are
  exposed via Gateway API HTTPRoutes defined in the observability playbook and
  gated by Traefik ForwardAuth → Authentik.

  Grafana is configured for anonymous admin access on the assumption that
  ForwardAuth fronts the UI. The chart-generated admin user in the
  kube-prometheus-stack-grafana Secret is left in place but is not consumed by
  any meaningful auth path: the UI never prompts for it (anonymous admin), the
  HTTP API is gated by ForwardAuth at the gateway, and the in-pod
  dashboards-sidecar reaches Grafana over localhost where anonymous admin
  applies. No credential is injected from Ansible.

  Prometheus is configured to discover ServiceMonitors across all namespaces.
  Grafana's root_url is set to the HTTPS hostname so that redirect links and
  OAuth callbacks resolve correctly.

  The Grafana sidecar is configured to watch for ConfigMaps labelled
  grafana_dashboard: '1' in all namespaces and provision them automatically as
  dashboards.

  Variables:
    grafana_hostname: FQDN for the Grafana UI (e.g. grafana.homelab.internal).
#}
grafana:
  ingress:
    enabled: false
  grafana.ini:
    server:
      root_url: 'https://{{ grafana_hostname }}'
    auth.anonymous:
      enabled: true
      org_role: Admin
    dashboards:
      default_home_dashboard_path: /tmp/dashboards/node-metrics.json
  sidecar:
    dashboards:
      enabled: true
      label: grafana_dashboard
      labelValue: '1'
      searchNamespace: ALL

prometheus:
  ingress:
    enabled: false
  prometheusSpec:
    retention: 30d
    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false

alertmanager:
  ingress:
    enabled: false
