{#
  Helm values for Traefik ingress controller.

  Configures Traefik to act as a Gateway API controller using the kubernetesGateway
  provider. The kubernetesCRD provider is also enabled with cross-namespace access so
  that Middleware resources defined in one namespace can be referenced by routes in
  other namespaces. The kubernetesIngress provider is disabled as Gateway API HTTPRoutes
  are used exclusively. A LoadBalancer service is created so Traefik receives a stable
  LAN IP from the Cilium IP pool. HTTP traffic is redirected to HTTPS by the web
  entrypoint redirect. The built-in dashboard ingressRoute is disabled in favor of
  the manually created HTTPRoute. Access logs are enabled for observability.

  The namespace runs under Pod Security Admission 'restricted'. The pod runs
  as nonroot_uid (65532) on the chart's built-in distroless image, which
  already has a `nonroot` user at that UID. The container listens on
  non-privileged 8000/8443 internally and the LoadBalancer Service maps
  external 80/443 onto them, so no NET_BIND_SERVICE capability is needed.
  The chart's built-in podSecurityContext and securityContext defaults are
  close to restricted but omit `seccompProfile` and `fsGroup`, so the
  overrides below re-declare the full restricted set (Helm replaces these
  top-level maps wholesale rather than merging, so every required field
  has to be repeated even when the chart already sets it).

  The kubernetesCRD provider is configured to watch all namespaces (no allowlist).
  This lets services define their own ForwardAuth Middleware in their own namespace
  without requiring this file (and a Helm upgrade) to be updated each time a new
  service is added.

  Variables:
    traefik_http_port:  External LoadBalancer port for HTTP (the web entrypoint).
                        Derived from ufw_allowed_ports.traefik_http.port in group_vars.
    traefik_https_port: External LoadBalancer port for HTTPS (the websecure entrypoint).
                        Derived from ufw_allowed_ports.traefik_https.port in group_vars.
    nonroot_uid:        Shared non-root UID for the Traefik pod. Read from group_vars.
#}
providers:
  kubernetesGateway:
    enabled: true
  kubernetesCRD:
    enabled: true
    allowCrossNamespace: true
  kubernetesIngress:
    enabled: false

service:
  type: LoadBalancer

ports:
  traefik:
    expose:
      default: true
  web:
    exposedPort: {{ traefik_http_port }}
    redirections:
      entryPoint:
        to: websecure
        scheme: https
  websecure:
    exposedPort: {{ traefik_https_port }}

gateway:
  enabled: false

additionalArguments:
  - '--api.insecure=true'

ingressRoute:
  dashboard:
    enabled: false

accessLog:
  enabled: true

podSecurityContext:
  runAsNonRoot: true
  runAsUser: {{ nonroot_uid }}
  runAsGroup: {{ nonroot_uid }}
  fsGroup: {{ nonroot_uid }}
  seccompProfile:
    type: RuntimeDefault

securityContext:
  allowPrivilegeEscalation: false
  capabilities:
    drop:
      - ALL
  readOnlyRootFilesystem: true
  seccompProfile:
    type: RuntimeDefault
